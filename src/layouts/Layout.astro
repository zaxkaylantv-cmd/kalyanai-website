---
import Footer from '../components/Footer.astro';
import Nav from '../components/Nav.astro';
import CTASection from '../components/CTASection.astro';
import '../styles/global.css';

const {
	title = 'Kalyan AI | AI Systems That Make Business Easier to Run, Control and Grow',
	description = 'We build AI systems that make your business easier to run, control and grow.',
	showFinalCta = true,
} = Astro.props;

const siteUrl = Astro.site?.toString() ?? 'https://www.kalyanai.io';
const canonicalUrl = Astro.url ? new URL(Astro.url.pathname, siteUrl).toString() : siteUrl;
const ogImageUrl = new URL('/og-kalyan-ai-2026-refined-v1.png', siteUrl).toString();
const ogImageAlt = 'Kalyan AI. AI systems that make your business easier to run, control and grow.';
const ogTitle = title;
const ogDescription = description;
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" href="/favicon.ico?v=20260629" sizes="any" />
		<link rel="icon" type="image/png" href="/favicon-32x32.png?v=20260629" sizes="32x32" />
		<link rel="icon" type="image/png" href="/favicon-16x16.png?v=20260629" sizes="16x16" />
		<link rel="apple-touch-icon" href="/apple-touch-icon-180x180.png?v=20260629" />
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link
			href="https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght@9..144,400;9..144,500;9..144,600;9..144,700&family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@500&display=swap"
			rel="stylesheet"
		/>
		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>
		<meta name="description" content={description} />
		<meta name="robots" content="index, follow" />
		<link rel="canonical" href={canonicalUrl} />
		<meta property="og:locale" content="en_GB" />
		<meta property="og:site_name" content="Kalyan AI" />
		<meta property="og:type" content="website" />
		<meta property="og:title" content={ogTitle} />
		<meta property="og:description" content={ogDescription} />
		<meta property="og:url" content={canonicalUrl} />
		<meta property="og:image" content={ogImageUrl} />
		<meta property="og:image:secure_url" content={ogImageUrl} />
		<meta property="og:image:alt" content={ogImageAlt} />
		<meta property="og:image:type" content="image/png" />
		<meta property="og:image:width" content="1200" />
		<meta property="og:image:height" content="630" />
		<meta name="twitter:card" content="summary_large_image" />
		<meta name="twitter:title" content={ogTitle} />
		<meta name="twitter:description" content={ogDescription} />
		<meta name="twitter:image" content={ogImageUrl} />
		<meta name="twitter:image:alt" content={ogImageAlt} />
		<meta name="twitter:url" content={canonicalUrl} />
		<script defer data-domain="www.kalyanai.io" src="https://plausible.io/js/script.js"></script>
	</head>
	<body>
		<Nav />
		<main id="content">
			<slot />
		</main>
		{showFinalCta && <CTASection />}
		<Footer />

		<script is:inline>
			if (typeof window !== 'undefined') {
				document.addEventListener('click', (event) => {
					const target = event.target;
					const node = target instanceof Element ? target.closest('[data-plausible]') : null;
					const eventName = node?.getAttribute('data-plausible');
					if (eventName && typeof window.plausible === 'function') {
						window.plausible(eventName);
					}
				});
			}
		</script>
	</body>
</html>
