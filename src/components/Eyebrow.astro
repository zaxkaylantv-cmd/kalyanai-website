---
interface Props {
	tone?: 'light' | 'dark';
	class?: string;
}

const { tone = 'light', class: className = '' } = Astro.props as Props;
---

<p class:list={['ka-eyebrow', `ka-eyebrow--${tone}`, className]}>
	<slot />
</p>

<style>
	.ka-eyebrow {
		display: inline-flex;
		align-items: center;
		gap: 10px;
		margin: 0 0 16px;
		font-family: "JetBrains Mono", ui-monospace, SFMono-Regular, Menlo, monospace;
		font-size: 12px;
		font-weight: 500;
		letter-spacing: 0.17em;
		line-height: 1.3;
		text-transform: uppercase;
	}

	.ka-eyebrow::before {
		content: "";
		width: 8px;
		height: 8px;
		flex: 0 0 auto;
		background: var(--gold);
	}

	.ka-eyebrow--light {
		color: var(--teal-deep);
	}

	.ka-eyebrow--dark {
		color: var(--teal-soft);
	}

	.ka-eyebrow--dark::before {
		background: var(--gold-soft);
	}
</style>
