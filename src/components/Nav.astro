---
const navLinks = [
	{ label: 'About', href: '/about' },
	{ label: 'Blueprint', href: '/blueprint' },
	{ label: 'Case studies', href: '/case-studies/' },
	{ label: 'How we build', href: '/how-we-build' },
	{ label: 'Contact', href: '/contact' },
];
---

<header class="ka-nav-shell">
	<div class="ka-wrap">
		<nav class="ka-nav" aria-label="Main navigation">
			<a class="ka-brand" href="/" aria-label="Kalyan AI home">
				<span class="ka-brand__logo">KALYAN <span>AI</span></span>
				<span class="ka-brand__tag">Your Implementation Partner</span>
			</a>
			<div class="ka-nav__links ka-nav__links--desktop">
				{navLinks.map((link) => (
					<a href={link.href}>{link.label}</a>
				))}
			</div>
			<div class="ka-nav__mobile">
				<button class="ka-nav__toggle" type="button" aria-expanded="false" aria-controls="ka-mobile-nav">
					<span>Menu</span>
					<span class="ka-nav__icon" aria-hidden="true">
						<span></span>
						<span></span>
						<span></span>
					</span>
				</button>
				<div class="ka-nav__panel" id="ka-mobile-nav" hidden>
					{navLinks.map((link) => (
						<a href={link.href}>{link.label}</a>
					))}
				</div>
			</div>
		</nav>
	</div>
</header>

<script is:inline>
	if (typeof window !== 'undefined') {
		const toggle = document.querySelector('.ka-nav__toggle');
		const panel = document.getElementById('ka-mobile-nav');
		if (toggle && panel) {
			const setOpen = (open) => {
				toggle.setAttribute('aria-expanded', String(open));
				panel.hidden = !open;
			};
			toggle.addEventListener('click', () => {
				const open = toggle.getAttribute('aria-expanded') === 'true';
				setOpen(!open);
			});
			panel.addEventListener('click', (event) => {
				const target = event.target;
				if (target instanceof HTMLAnchorElement) setOpen(false);
			});
			window.addEventListener('resize', () => {
				if (window.innerWidth > 860) setOpen(false);
			});
		}
	}
</script>

<style>
	.ka-nav-shell {
		position: relative;
		z-index: 20;
		background: var(--navy-deep);
	}

	.ka-nav {
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 28px;
		padding: 24px 0;
	}

	.ka-brand {
		display: flex;
		flex: 0 0 auto;
		flex-direction: column;
		gap: 4px;
		color: var(--white);
		line-height: 1;
		text-decoration: none;
	}

	.ka-brand__logo {
		font-family: "Fraunces", Georgia, serif;
		font-size: 22px;
		font-weight: 600;
		letter-spacing: 0;
	}

	.ka-brand__logo span {
		color: var(--teal-soft);
	}

	.ka-brand__tag {
		color: var(--body-light);
		font-family: "JetBrains Mono", ui-monospace, SFMono-Regular, Menlo, monospace;
		font-size: 10px;
		font-weight: 500;
		letter-spacing: 0.18em;
		text-transform: uppercase;
	}

	.ka-nav__links--desktop {
		display: flex;
		align-items: center;
		justify-content: flex-end;
		gap: 34px;
	}

	.ka-nav__links--desktop a,
	.ka-nav__panel a {
		color: var(--body-light);
		font-size: 14.5px;
		font-weight: 600;
		text-decoration: none;
		transition: color 150ms ease;
	}

	.ka-nav__links--desktop a:hover,
	.ka-nav__panel a:hover {
		color: var(--white);
	}

	.ka-nav__mobile {
		display: none;
	}

	.ka-nav__toggle {
		display: inline-flex;
		align-items: center;
		gap: 12px;
		min-height: 44px;
		padding: 10px 14px;
		border: 1px solid rgba(255, 255, 255, 0.12);
		border-radius: 10px;
		background: rgba(255, 255, 255, 0.04);
		color: var(--white);
		font-family: inherit;
		font-size: 14px;
		font-weight: 700;
		line-height: 1;
		cursor: pointer;
	}

	.ka-nav__icon {
		display: grid;
		gap: 3px;
		width: 16px;
	}

	.ka-nav__icon span {
		display: block;
		height: 2px;
		border-radius: 999px;
		background: var(--teal-soft);
	}

	.ka-nav__panel {
		display: grid;
		gap: 12px;
		padding: 14px 0 18px;
	}

	.ka-nav__panel a {
		display: block;
		padding: 4px 0;
	}

	@media (max-width: 860px) {
		.ka-nav {
			align-items: flex-start;
			flex-direction: column;
			gap: 14px;
			padding-bottom: 14px;
		}

		.ka-nav__links--desktop {
			display: none;
		}

		.ka-nav__mobile {
			display: block;
			width: 100%;
		}

		.ka-nav__toggle {
			margin-left: auto;
		}
	}
</style>
