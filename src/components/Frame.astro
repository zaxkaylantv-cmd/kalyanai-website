---
interface Props {
	src: string;
	alt: string;
	label?: string;
	badge?: string;
	loading?: 'lazy' | 'eager';
	class?: string;
	imageFit?: 'cover' | 'contain';
}

const {
	src,
	alt,
	label,
	badge,
	loading = 'lazy',
	class: className = '',
	imageFit = 'cover',
} = Astro.props as Props;
---

<figure class:list={['ka-frame', className]}>
	<div class="ka-frame__chrome" aria-hidden="true">
		<span></span>
		<span></span>
		<span></span>
		<div></div>
	</div>
	<div class="ka-frame__screen">
		{badge && <span class="ka-frame__badge">{badge}</span>}
		<img src={src} alt={alt} loading={loading} decoding="async" data-fit={imageFit} />
	</div>
	{label && <figcaption>{label}</figcaption>}
</figure>

<style>
	.ka-frame {
		margin: 0;
	}

	.ka-frame__chrome {
		display: flex;
		align-items: center;
		gap: 6px;
		padding: 11px 14px;
		border: 1px solid var(--line-light);
		border-bottom: 0;
		border-radius: 13px 13px 0 0;
		background: var(--white);
	}

	.ka-frame__chrome span {
		width: 9px;
		height: 9px;
		border-radius: 999px;
		background: #d8e0ea;
	}

	.ka-frame__chrome div {
		height: 8px;
		flex: 1;
		max-width: 180px;
		margin-left: 10px;
		border-radius: 999px;
		background: #eef3f7;
	}

	.ka-frame__screen {
		position: relative;
		overflow: hidden;
		aspect-ratio: 16 / 10;
		border: 1px solid var(--line-light);
		border-radius: 0 0 13px 13px;
		background: var(--paper);
		box-shadow: 0 30px 60px -34px rgba(11, 18, 32, 0.34);
	}

	.ka-frame__screen img {
		display: block;
		width: 100%;
		height: 100%;
		object-position: top center;
	}

	.ka-frame__screen img[data-fit="cover"] {
		object-fit: cover;
	}

	.ka-frame__screen img[data-fit="contain"] {
		object-fit: contain;
		background: var(--paper);
	}

	.ka-frame__badge {
		position: absolute;
		z-index: 2;
		top: 13px;
		left: 13px;
		padding: 5px 9px;
		border-radius: 5px;
		background: rgba(7, 17, 31, 0.72);
		color: var(--teal-soft);
		font-family: "JetBrains Mono", ui-monospace, SFMono-Regular, Menlo, monospace;
		font-size: 10px;
		font-weight: 500;
		letter-spacing: 0.08em;
		line-height: 1;
		text-transform: uppercase;
	}

	figcaption {
		margin-top: 9px;
		color: #7c8b9c;
		font-family: "JetBrains Mono", ui-monospace, SFMono-Regular, Menlo, monospace;
		font-size: 11px;
		line-height: 1.5;
		text-align: left;
	}
</style>
