---
import ButtonGhost from './ButtonGhost.astro';
import ButtonPrimary from './ButtonPrimary.astro';
---

<section class="ka-home-hero">
	<div class="ka-mesh" aria-hidden="true">
		<div class="ka-blob ka-blob-3"></div>
		<div class="ka-blob ka-blob-1"></div>
		<div class="ka-blob ka-blob-2"></div>
		<div class="ka-blob ka-blob-6"></div>
		<div class="ka-blob ka-blob-4"></div>
		<div class="ka-blob ka-blob-5"></div>
	</div>
	<div class="ka-sweep" aria-hidden="true"></div>
	<div class="ka-grain" aria-hidden="true"></div>

	<div class="ka-wrap">
		<div class="ka-home-hero__content">
			<p class="ka-home-hero__kicker">AI systems for owner led businesses</p>
			<h1>
				We build AI systems that make your business easier to
				<span>run</span>, <span>control</span> and <span>grow</span>.
			</h1>
			<p class="ka-home-hero__lead">
				We learn how your business works, find where AI can create real value, and build the right system around it.
			</p>
			<div class="ka-home-hero__actions">
				<ButtonPrimary href="/blueprint" label="Start with the Blueprint" data-plausible="BookACall" />
				<ButtonGhost href="/how-we-build" label="See how we work" />
			</div>
		</div>
	</div>
</section>

<style>
	.ka-home-hero {
		position: relative;
		overflow: hidden;
		min-height: calc(100dvh - 92px);
		background: var(--navy-deep);
		color: var(--white);
	}

	.ka-home-hero::before,
	.ka-home-hero::after {
		content: "";
		position: absolute;
		inset: 0;
		z-index: 1;
		pointer-events: none;
	}

	.ka-home-hero::before {
		background: linear-gradient(100deg, var(--navy-deep) 26%, rgba(8, 20, 40, 0.72) 46%, transparent 72%);
	}

	.ka-home-hero::after {
		background: linear-gradient(180deg, rgba(8, 20, 40, 0.5), transparent 30%, transparent 70%, rgba(8, 20, 40, 0.92));
	}

	.ka-home-hero__content {
		position: relative;
		z-index: 4;
		max-width: 820px;
		padding: 96px 0 128px;
		text-align: left;
	}

	.ka-home-hero__kicker {
		margin: 0 0 26px;
		color: var(--teal-soft);
		font-family: "JetBrains Mono", ui-monospace, SFMono-Regular, Menlo, monospace;
		font-size: 12px;
		font-weight: 500;
		letter-spacing: 0.16em;
		line-height: 1.4;
		text-transform: uppercase;
	}

	.ka-home-hero h1 {
		max-width: 16ch;
		margin: 0 0 30px;
		color: var(--white);
		font-size: clamp(44px, 6vw, 74px);
		font-weight: 500;
		letter-spacing: 0;
		text-shadow: 0 2px 40px rgba(0, 0, 0, 0.30);
	}

	.ka-home-hero h1 span {
		color: var(--teal-soft);
		font-weight: 600;
	}

	.ka-home-hero__lead {
		max-width: 44ch;
		margin-bottom: 38px;
		color: var(--body-light);
		font-size: 19px;
		line-height: 1.62;
	}

	.ka-home-hero__actions {
		display: flex;
		align-items: center;
		flex-wrap: wrap;
		gap: 18px;
	}

	@media (max-width: 640px) {
		.ka-home-hero {
			min-height: auto;
		}

		.ka-home-hero__content {
			padding: 72px 0 96px;
		}

		.ka-home-hero h1 {
			font-size: clamp(42px, 14vw, 58px);
		}
	}
</style>
