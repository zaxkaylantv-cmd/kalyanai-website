---
import Layout from '../layouts/Layout.astro';

const videos = [
	{
		title: 'Spa by Kaajal finance system',
		type: 'youtube',
		id: 'Sx6ZVQ_EYSg',
		description:
			'An example of a system Kalyan AI has built for finance admin and owner visibility. It brings invoices, receipts, tips, missing items and accountant-ready exports into one controlled view.',
	},
	{
		title: 'Business system example',
		type: 'youtube',
		id: '0Am1DEJEY2k',
		description:
			'An example of a system Kalyan AI has built around real business operations. It shows how information, actions and owner review can sit together in a practical system.',
	},
	{
		title: 'Systems built around real operations',
		type: 'youtube',
		id: '1c0JG1CSYLg',
		description:
			'An example of systems Kalyan AI has built to support day-to-day business work. It shows how the right system can make important work easier to see and manage.',
	},
	{
		title: 'Kalyan AI overview',
		type: 'local',
		src: '/video/automation-showcase.mp4',
		poster: '/video/automation-showcase-thumb.jpg',
		description:
			'A short explainer about Kalyan AI and the kind of practical business problems we help with. This is an overview, not a client system.',
	},
	{
		title: 'What Kalyan AI builds',
		type: 'local',
		src: '/video/kalyan-explainer.mp4',
		poster: '/video/kalyan-explainer.jpg',
		description:
			'A short practical example of how AI systems can support business owners. It explains the thinking behind our work without treating every business as the same.',
	},
];
---

<Layout
	title="System examples | Kalyan AI"
	description="See examples of systems and practical ideas in action, including real systems Kalyan AI has built and short explainers about how AI can support business owners."
>
	<main class="mx-auto flex w-full max-w-5xl flex-col gap-8 px-6 pb-16">
		<section class="ka-card mx-auto max-w-5xl space-y-3 rounded-3xl bg-white/80 p-6 text-center shadow-[0_10px_50px_-40px_rgba(0,0,0,0.5)] backdrop-blur md:p-8">
			<h1 class="text-3xl font-semibold text-[var(--brand-navy)]">System examples</h1>
			<p class="copy-narrow mx-auto max-w-3xl text-lg text-[var(--primary)]">
				See examples of systems and practical ideas in action.
			</p>
			<p class="copy-narrow mx-auto max-w-3xl text-[var(--muted)]">
				These videos include real systems Kalyan AI has built, plus short explainers showing how AI can make a business easier to run and grow.
			</p>
		</section>

		<section class="grid gap-8">
			{videos.map((video) => (
				<article class="ka-card space-y-4 rounded-3xl bg-white/80 p-5 shadow-[0_10px_50px_-40px_rgba(0,0,0,0.5)] backdrop-blur md:p-6">
					<div class="space-y-2 text-center">
						<h2 class="text-xl font-semibold text-[var(--brand-navy)]">{video.title}</h2>
						<p class="copy-narrow mx-auto text-[var(--muted)]">{video.description}</p>
					</div>
					<div class="aspect-video overflow-hidden rounded-xl border border-[var(--border-subtle)] bg-black/5 shadow-sm">
						{video.type === 'youtube' ? (
							<iframe
								class="h-full w-full"
								src={`https://www.youtube.com/embed/${video.id}?rel=0&modestbranding=1`}
								title={video.title}
								allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
								allowfullscreen
								loading="lazy"
							></iframe>
						) : (
							<video
								class="h-full w-full object-cover"
								controls
								preload="metadata"
								playsinline
								poster={video.poster}
							>
								<source src={video.src} type="video/mp4" />
								Your browser does not support the video tag.
							</video>
						)}
					</div>
				</article>
			))}
		</section>
	</main>
</Layout>
