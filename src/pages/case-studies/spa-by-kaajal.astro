---
import ButtonPrimary from '../../components/ButtonPrimary.astro';
import Eyebrow from '../../components/Eyebrow.astro';
import Layout from '../../layouts/Layout.astro';
import SectionHeading from '../../components/SectionHeading.astro';

const builtItems = [
	{
		title: 'Invoices',
		copy: 'Pulled in from email or uploaded manually with drag and drop, so documents could be handled consistently.',
	},
	{
		title: 'Receipts',
		copy: 'Quick photo upload from a phone, so items could be captured close to the moment they happened.',
	},
	{
		title: 'Tips',
		copy: 'A simple entry screen to replace informal notes with a clearer record.',
	},
	{
		title: 'Exports',
		copy: 'CSV packs for the accountant: invoices, receipts, or tips, separately or together.',
	},
];

const safeguards = [
	'Documents go straight to secure cloud storage, so nothing sensitive sits on a server.',
	'Duplicate prevention if the same invoice comes in twice.',
	'Clear statuses so items are easier to review.',
	'Full record of what came in and when.',
	'Secure sign-in with locked-down access.',
];
---

<Layout title="Spa by Kaajal Case Study | Finance Admin Reduced to Around 30 Minutes" description="How Kalyan AI helped Spa by Kaajal reduce finance admin from around 4 to 6 hours a week to around 30 minutes with a practical business system." showFinalCta={false}>
	<section class="case-hero">
		<div class="ka-wrap">
			<div class="case-hero__grid">
				<div>
					<Eyebrow tone="dark">Finance operations</Eyebrow>
					<h1>Spa by Kaajal finance system</h1>
					<p>A system built around how finance work moved through the salon, giving the owner one clearer place for invoices, receipts, tips and accountant-ready exports.</p>
				</div>
				<div class="case-hero__stat" aria-label="Finance admin reduced from around 4 to 6 hours a week to around 30 minutes">
					<span>Weekly finance admin</span>
					<strong>4-6 hrs to 30 min</strong>
					<p>Reduced from around 4 to 6 hours a week to around 30 minutes after the system went live.</p>
				</div>
			</div>
		</div>
	</section>

	<section class="ka-section ka-section-dark case-context">
		<div class="ka-wrap">
			<div class="case-two-col">
				<SectionHeading
					eyebrow="Business context"
					title="Finance work needed one clearer source of truth."
					highlight="one clearer source of truth."
					tone="dark"
				/>
				<div class="case-copy">
					<p>Spa by Kaajal needed a better way to handle invoices, receipts, tips, accountant exports, and the decisions around what had been captured or still needed attention.</p>
					<p>The work was spread across email, WhatsApp, paper, notebooks, and existing files. The owner needed one place to understand what had come in, what was missing, and what needed action.</p>
					<p>The goal was not to force a new way of running the salon. It was to build a system around how the finance work already moved through the business, with clearer status, stronger owner control, and accountant-ready outputs.</p>
				</div>
			</div>
		</div>
	</section>

	<section class="ka-section ka-section-white case-built">
		<div class="ka-wrap">
			<div class="case-built-grid">
				<div>
					<SectionHeading
						eyebrow="What we built"
						title="A finance system for capture, review and export."
						highlight="capture, review and export."
						lead="A single finance system that captures invoices, receipts, and tips into one place, with clear status tracking, owner review, and exports the accountant can use."
					/>
					<div class="case-feature-list">
						{builtItems.map((item) => (
							<article>
								<h3>{item.title}</h3>
								<p>{item.copy}</p>
							</article>
						))}
					</div>
				</div>
			</div>
		</div>
	</section>

	<section class="ka-section ka-section-white case-proof-band">
		<div class="ka-wrap">
			<SectionHeading
				eyebrow="Before and after"
				title="From scattered records to one controlled finance view."
				lead="Images are blurred or use demo data for privacy. The layout shows the real operating problem and the system delivered."
			/>
			<div class="spa-before-after">
				<div class="spa-proof-column">
					<div>
						<span>Before</span>
						<h3>Fragmented finance records</h3>
						<p>Multiple files and notes, with no single source of truth.</p>
					</div>
					<ul>
						<li>Finance information lived across several places.</li>
						<li>Review status was harder to see at a glance.</li>
						<li>Accountant-ready exports took repeated manual work.</li>
					</ul>
					<div class="spa-before-evidence" aria-label="Blurred examples of previous finance records">
						<figure class="spa-before-file">
							<div class="spa-before-file__chrome" aria-hidden="true">
								<span></span>
								<span></span>
								<span></span>
								<div></div>
							</div>
							<div class="spa-before-file__screen spa-before-file__screen--vouchers">
								<img
									src="/images/case-studies/before-vouchers.jpg"
									alt="Blurred example of previous voucher finance records before the Spa by Kaajal system."
									loading="eager"
									decoding="async"
								/>
							</div>
							<figcaption>Voucher records before</figcaption>
						</figure>
						<figure class="spa-before-file">
							<div class="spa-before-file__chrome" aria-hidden="true">
								<span></span>
								<span></span>
								<span></span>
								<div></div>
							</div>
							<div class="spa-before-file__screen spa-before-file__screen--expenses">
								<img
									src="/images/case-studies/before-expenses.jpg"
									alt="Blurred example of previous expense finance records before the Spa by Kaajal system."
									loading="eager"
									decoding="async"
								/>
							</div>
							<figcaption>Expense records before</figcaption>
						</figure>
					</div>
				</div>
				<div class="spa-proof-column">
					<div>
						<span>After</span>
						<h3>One clean system</h3>
						<p>Everything in one place with clear status tracking, owner review, and accountant-ready exports.</p>
					</div>
					<ul>
						<li>Invoices, receipts and tips moved into one operating view.</li>
						<li>Owner review and item status became clearer.</li>
						<li>Exports could be prepared in a controlled way.</li>
					</ul>
					<figure class="spa-after-frame">
						<div class="spa-after-frame__chrome" aria-hidden="true">
							<span></span>
							<span></span>
							<span></span>
							<div></div>
						</div>
						<div class="spa-after-frame__screen">
							<img
								src="/images/case-studies/after-dashboard.png"
								alt="Spa by Kaajal finance dashboard showing invoices, receipts, cashflow, tips and overdue items in one place."
								width="872"
								height="572"
								loading="eager"
								fetchpriority="high"
							/>
						</div>
						<figcaption>Finance dashboard with demo data</figcaption>
					</figure>
				</div>
			</div>
		</div>
	</section>

	<section class="ka-section ka-section-white case-results">
		<div class="ka-wrap">
			<div class="case-results__grid">
				<div>
					<SectionHeading
						eyebrow="Results and safeguards"
						title="The result was clearer finance control with less weekly admin."
						highlight="less weekly admin."
						lead="Finance admin reduced from around 4 to 6 hours a week to around 30 minutes."
					/>
					<ul class="case-check-list">
						{safeguards.map((item) => (
							<li><span></span>{item}</li>
						))}
					</ul>
				</div>
				<article class="case-review">
					<p class="case-stars" aria-label="Five star review">*****</p>
					<blockquote>I was spending 4 to 6 hours a week on finance admin. Zax took the time to understand how my salon works and built a system around it. Now everything is in one place, I know what's going on, and getting things ready for my accountant is so much easier. He made sure I was comfortable using it and was always available when I had questions.</blockquote>
					<footer>Kaajal Malik, Spa by Kaajal</footer>
				</article>
			</div>
		</div>
	</section>

	<section class="ka-section ka-section-deep case-cta">
		<div class="ka-wrap">
			<div class="case-cta__inner">
				<Eyebrow>Start here</Eyebrow>
				<h2>Want to find the right first system for your business?</h2>
				<p>The Business AI Blueprint is a focused paid review that helps identify where AI can create real value, what system is worth building first, and whether there is a clear business case before a larger build.</p>
				<ButtonPrimary href="/blueprint" label="Start with the Business AI Blueprint" data-plausible="BookACall" />
			</div>
		</div>
	</section>
</Layout>

<style>
	.case-hero {
		background:
			linear-gradient(100deg, rgba(8, 20, 40, 0.98) 22%, rgba(8, 20, 40, 0.76) 62%, rgba(8, 20, 40, 0.98) 100%),
			radial-gradient(circle at 80% 24%, rgba(0, 183, 198, 0.22), transparent 34%),
			var(--navy-deep);
		border-bottom: 1px solid var(--line-dark);
		color: var(--white);
	}

	.case-hero__grid {
		display: grid;
		grid-template-columns: 1fr 0.75fr;
		gap: 64px;
		align-items: end;
		padding: 116px 0 132px;
	}

	.case-hero h1 {
		max-width: 13ch;
		margin: 0 0 24px;
		color: var(--white);
		font-size: clamp(46px, 6vw, 76px);
		font-weight: 500;
	}

	.case-hero p,
	.case-hero__stat p {
		color: var(--body-light);
		font-size: 18px;
		line-height: 1.66;
	}

	.case-hero__stat {
		padding: 30px;
		border: 1px solid var(--line-dark);
		border-radius: 16px;
		background: rgba(255, 255, 255, 0.05);
		text-align: left;
	}

	.case-hero__stat span,
	.spa-proof-column span {
		color: var(--teal-soft);
		font-family: "JetBrains Mono", ui-monospace, SFMono-Regular, Menlo, monospace;
		font-size: 11px;
		letter-spacing: 0.09em;
		text-transform: uppercase;
	}

	.case-hero__stat strong {
		display: block;
		margin: 14px 0 12px;
		color: var(--gold-soft);
		font-family: "Fraunces", Georgia, serif;
		font-size: clamp(34px, 4vw, 52px);
		font-weight: 600;
		line-height: 1;
	}

	.case-context {
		background: var(--navy);
		border-bottom: 1px solid var(--line-dark);
	}

	.case-context .case-copy {
		color: var(--body-light);
	}

	.case-built {
		border-bottom: 1px solid var(--line-light);
	}

	.case-two-col,
	.case-built-grid,
	.case-results__grid {
		display: grid;
		grid-template-columns: 0.9fr 1.1fr;
		gap: 64px;
		align-items: start;
	}

	.case-copy {
		display: grid;
		gap: 18px;
		max-width: 58ch;
		color: var(--body);
		font-size: 17px;
		line-height: 1.68;
		text-align: left;
	}

	.case-feature-list {
		display: grid;
		grid-template-columns: 1fr 1fr;
		gap: 14px;
		margin-top: 34px;
	}

	.case-feature-list article,
	.case-review,
	.case-cta__inner {
		border: 1px solid var(--line-light);
		border-radius: 16px;
		background: var(--white);
		box-shadow: 0 28px 58px -48px rgba(11, 18, 32, 0.28);
		text-align: left;
	}

	.case-feature-list article {
		padding: 22px;
	}

	.case-feature-list h3,
	.spa-proof-column h3 {
		margin: 0 0 8px;
		color: var(--ink);
		font-size: 21px;
		font-weight: 600;
	}

	.case-feature-list p {
		color: var(--body);
		font-size: 15px;
		line-height: 1.6;
	}

	.case-proof-band {
		position: relative;
		overflow: hidden;
		border-bottom: 1px solid var(--line-light);
	}

	.case-proof-band::before {
		content: "";
		position: absolute;
		inset: auto -8% -30% 48%;
		height: 520px;
		background: radial-gradient(circle, rgba(0, 183, 198, 0.08), transparent 68%);
		pointer-events: none;
	}

	.spa-before-after {
		position: relative;
		z-index: 2;
		display: grid;
		grid-template-columns: 0.92fr 1.08fr;
		gap: 22px;
		margin-top: 58px;
	}

	.spa-proof-column {
		padding: 26px;
		border: 1px solid var(--line-light);
		border-radius: 16px;
		background: var(--white);
		box-shadow: 0 28px 58px -48px rgba(11, 18, 32, 0.28);
		text-align: left;
	}

	.spa-proof-column h3 {
		margin-top: 12px;
		color: var(--ink);
	}

	.spa-proof-column p {
		color: var(--body);
		font-size: 15px;
		line-height: 1.62;
	}

	.case-check-list {
		display: grid;
		gap: 14px;
		margin: 32px 0 0;
		padding: 0;
		list-style: none;
	}

	.case-check-list li {
		display: grid;
		grid-template-columns: 18px 1fr;
		gap: 12px;
		color: var(--body);
		font-size: 15px;
		line-height: 1.58;
	}

	.spa-proof-column ul {
		display: grid;
		gap: 12px;
		margin: 24px 0 0;
		padding: 0;
		list-style: none;
	}

	.spa-proof-column li {
		position: relative;
		padding-left: 18px;
		color: var(--body);
		font-size: 15px;
		line-height: 1.58;
	}

	.spa-proof-column li::before {
		content: "";
		position: absolute;
		top: 0.65em;
		left: 0;
		width: 7px;
		height: 7px;
		border-radius: 999px;
		background: var(--teal);
	}

	.spa-before-evidence {
		display: grid;
		grid-template-columns: 1fr;
		gap: 14px;
		margin-top: 26px;
	}

	.spa-before-file {
		margin: 0;
	}

	.spa-before-file__chrome {
		display: flex;
		align-items: center;
		gap: 6px;
		padding: 8px;
		border: 1px solid var(--line-light);
		border-bottom: 0;
		border-radius: 13px 13px 0 0;
		background: var(--white);
	}

	.spa-before-file__chrome span {
		width: 9px;
		height: 9px;
		border-radius: 999px;
		background: #d8e0ea;
	}

	.spa-before-file__chrome div {
		height: 8px;
		flex: 1;
		max-width: 180px;
		margin-left: 10px;
		border-radius: 999px;
		background: #eef3f7;
	}

	.spa-before-file__screen {
		overflow: hidden;
		aspect-ratio: 16 / 9;
		border: 1px solid var(--line-light);
		border-radius: 0 0 13px 13px;
		background: #f4f7fb;
		background-position: top center;
		background-repeat: no-repeat;
		background-size: contain;
		box-shadow: 0 22px 36px -28px rgba(11, 18, 32, 0.34);
	}

	.spa-before-file__screen--vouchers {
		background-image: url("/images/case-studies/before-vouchers.jpg");
	}

	.spa-before-file__screen--expenses {
		background-image: url("/images/case-studies/before-expenses.jpg");
	}

	.spa-before-file__screen img {
		display: block;
		width: 100%;
		height: 100%;
		object-fit: contain;
		object-position: top center;
		opacity: 0;
	}

	.spa-before-file figcaption {
		margin-top: 9px;
		color: #7c8b9c;
		font-family: "JetBrains Mono", ui-monospace, SFMono-Regular, Menlo, monospace;
		font-size: 10px;
		line-height: 1.5;
		text-align: left;
	}

	.spa-after-frame {
		margin-top: 24px;
	}

	.spa-after-frame__chrome {
		display: flex;
		align-items: center;
		gap: 6px;
		padding: 11px 14px;
		border: 1px solid var(--line-light);
		border-bottom: 0;
		border-radius: 13px 13px 0 0;
		background: var(--white);
	}

	.spa-after-frame__chrome span {
		width: 9px;
		height: 9px;
		border-radius: 999px;
		background: #d8e0ea;
	}

	.spa-after-frame__chrome div {
		height: 8px;
		flex: 1;
		max-width: 180px;
		margin-left: 10px;
		border-radius: 999px;
		background: #eef3f7;
	}

	.spa-after-frame__screen {
		overflow: visible;
		border: 1px solid var(--line-light);
		border-radius: 0 0 13px 13px;
		background: #f6f9fc;
		box-shadow: 0 30px 58px -34px rgba(11, 18, 32, 0.38);
	}

	.spa-after-frame__screen img {
		display: block;
		width: 100%;
		max-width: 100%;
		height: auto;
		object-fit: contain;
		object-position: center;
		position: static;
		opacity: 1;
		background: #f6f9fc;
		filter: none;
	}

	.spa-after-frame figcaption {
		margin-top: 9px;
		color: #7c8b9c;
		font-family: "JetBrains Mono", ui-monospace, SFMono-Regular, Menlo, monospace;
		font-size: 11px;
		line-height: 1.5;
		text-align: left;
	}

	.case-check-list span {
		width: 8px;
		height: 8px;
		margin-top: 0.62em;
		border-radius: 999px;
		background: var(--teal);
	}

	.case-review {
		padding: 30px;
	}

	.case-stars {
		margin-bottom: 16px;
		color: #fbbc05;
		font-size: 16px;
		letter-spacing: 2px;
	}

	.case-review blockquote {
		margin: 0;
		color: var(--body);
		font-size: 17px;
		font-style: italic;
		line-height: 1.68;
	}

	.case-review footer {
		margin-top: 20px;
		color: var(--teal-deep);
		font-size: 14px;
		font-weight: 700;
	}

	.case-cta {
		background: var(--navy-deep);
		border-top: 1px solid var(--line-dark);
	}

	.case-cta__inner {
		max-width: 56ch;
		padding: 34px;
		border-color: var(--line-dark);
		background: rgba(255, 255, 255, 0.04);
		box-shadow: none;
	}

	.case-cta h2 {
		margin: 0 0 18px;
		color: var(--white);
		font-size: clamp(30px, 4vw, 44px);
		font-weight: 500;
	}

	.case-cta p {
		margin-bottom: 28px;
		color: var(--body-light);
		font-size: 16px;
		line-height: 1.66;
	}

	.case-cta :global(.ka-eyebrow--light) {
		color: var(--teal-soft);
	}

	.case-cta :global(.ka-eyebrow--light)::before {
		background: var(--gold-soft);
	}

	@media (min-width: 861px) {
		.case-built {
			padding-bottom: 78px;
		}

		.case-built-grid {
			display: block;
		}

		.case-built :global(.ka-section-heading) {
			max-width: 62ch;
		}

		.case-feature-list {
			grid-template-columns: repeat(4, minmax(0, 1fr));
			gap: 16px;
			margin-top: 38px;
		}

		.case-proof-band {
			padding-top: 72px;
			padding-bottom: 70px;
		}

		.case-results {
			padding-top: 74px;
		}

		.spa-before-after {
			gap: 18px;
			margin-top: 42px;
		}

		.spa-proof-column {
			padding: 22px;
		}

		.spa-proof-column h3 {
			margin-top: 10px;
		}

		.spa-proof-column ul {
			gap: 10px;
			margin-top: 18px;
		}

		.spa-before-evidence,
		.spa-after-frame {
			margin-top: 20px;
		}

		.spa-before-evidence {
			gap: 12px;
		}

		.spa-after-frame__chrome {
			padding: 9px 12px;
		}
	}

	@media (max-width: 860px) {
		.case-hero__grid,
		.case-two-col,
		.case-built-grid,
		.case-results__grid,
		.spa-before-after,
		.case-feature-list {
			grid-template-columns: 1fr;
		}
	}

	@media (min-width: 641px) and (max-width: 860px) {
		.case-feature-list {
			grid-template-columns: repeat(2, minmax(0, 1fr));
		}
	}

	@media (max-width: 640px) {
		.case-hero__grid {
			padding: 78px 0 92px;
		}

		.case-hero__stat,
		.spa-proof-column,
		.case-review,
		.case-cta__inner {
			padding: 22px;
		}

	}
</style>
