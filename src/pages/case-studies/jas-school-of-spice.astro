---
import ButtonPrimary from '../../components/ButtonPrimary.astro';
import Eyebrow from '../../components/Eyebrow.astro';
import Layout from '../../layouts/Layout.astro';
import SectionHeading from '../../components/SectionHeading.astro';

const builtGroups = [
	{
		title: 'Customer booking',
		items: ['Class browsing and online booking', 'Secure online payments through Stripe', 'Confirmation and reminder emails'],
	},
	{
		title: 'Gift vouchers and enquiries',
		items: ['Gift voucher purchase', 'Customer enquiry handling', 'Telegram alerts when attention is needed'],
	},
	{
		title: 'Owner controls',
		items: ['Protected controls for class dates, booking changes, voucher handling and customer communication', 'Ongoing support from Kalyan AI behind the scenes'],
	},
];

const journeyPhases = [
	{
		phase: 'Explore',
		summary: 'Customers can understand the class options and ask questions before booking.',
		steps: ['View available classes', 'Choose a date', 'Ask a question before booking'],
	},
	{
		phase: 'Book',
		summary: 'The booking flow handles the key customer actions while interest is active.',
		steps: ['Book a place', 'Pay online', 'Buy vouchers'],
	},
	{
		phase: 'Attend',
		summary: 'The system keeps the customer informed and gives the owner clearer operational visibility.',
		steps: ['Receive confirmation', 'Receive a reminder before the class'],
	},
];
---

<Layout
	title="Jas's School of Spice Case Study | Booking and Operations System"
	description="A live booking and operations system for Jas's School of Spice, covering bookings, payments, gift vouchers, customer messages and owner alerts."
	showFinalCta={false}
>
	<section class="case-hero">
		<div class="ka-wrap">
			<div class="case-hero__grid">
				<div>
					<Eyebrow tone="dark">Live booking and operations</Eyebrow>
					<h1>Jas's School of Spice booking system</h1>
					<p>A live booking and operations system built to help customers book, pay, buy vouchers and ask questions online, while giving the owner clearer control behind the scenes.</p>
				</div>
				<div class="case-hero__panel">
					<span>Booking operations</span>
					<strong>Bookings, payments, vouchers and owner controls in one operating flow.</strong>
				</div>
			</div>
		</div>
	</section>

	<section class="ka-section ka-section-dark case-context">
		<div class="ka-wrap">
			<div class="case-two-col">
				<SectionHeading
					eyebrow="Business context"
					title="The school needed more than a simple booking page."
					highlight="more than a simple booking page."
					tone="dark"
				/>
				<div class="case-copy">
					<p>The school needed a cleaner way for customers to view class dates, book places, pay securely, buy vouchers and ask questions without every step depending on manual messages.</p>
					<p>Behind the scenes, the system also needed to support class dates, capacity, vouchers, booking changes and customer communication, with Kalyan AI supporting the system after launch.</p>
					<p>The result needed to work for customers while keeping practical owner control over the operation.</p>
				</div>
			</div>
		</div>
	</section>

	<section class="ka-section ka-section-paper">
		<div class="ka-wrap">
			<div class="case-built-grid">
				<div>
					<SectionHeading
						eyebrow="What we built"
						title="A live booking and operations system."
						highlight="operations system."
						lead="Kalyan AI built a live system covering the customer journey and the protected controls needed to run it properly."
					/>
					<div class="case-feature-list">
						{builtGroups.map((group) => (
							<article>
								<h3>{group.title}</h3>
								<ul>
									{group.items.map((item) => (
										<li><span></span>{item}</li>
									))}
								</ul>
							</article>
						))}
					</div>
				</div>
				<figure class="jas-shot">
					<div class="jas-shot__chrome" aria-hidden="true">
							<span></span>
							<span></span>
							<span></span>
							<div></div>
						</div>
					<div class="jas-shot__screen">
						<img
							src="/images/case-studies/jas-school-of-spice/jas-school-of-spice-customer-homepage.png"
							alt="Jas's School of Spice customer homepage showing class options and booking calls to action."
							width="891"
							height="946"
							loading="eager"
							fetchpriority="high"
						/>
					</div>
					<figcaption>Customer booking homepage</figcaption>
				</figure>
			</div>
		</div>
	</section>

	<section class="ka-section ka-section-deep case-flow-band">
		<div class="ka-wrap">
			<SectionHeading
				eyebrow="Customer journey"
				title="A connected journey from interest to class attendance."
				lead="The public journey is connected to protected operational controls behind the scenes, so the owner keeps clearer control of classes, capacity and communication."
				tone="dark"
			/>
			<div class="jas-flow">
				{journeyPhases.map((phase, phaseIndex) => (
					<article class="jas-flow__phase">
						<div class="jas-flow__phase-head">
							<span>{phase.phase}</span>
							<p>{phase.summary}</p>
						</div>
						<ol>
							{phase.steps.map((step, stepIndex) => (
								<li>
									<strong>{String(phaseIndex * 3 + stepIndex + 1).padStart(2, '0')}</strong>
									<p>{step}</p>
								</li>
							))}
						</ol>
					</article>
				))}
			</div>
			<div class="case-dark-feature case-dark-feature--voucher">
				<div>
					<Eyebrow tone="dark">Voucher path</Eyebrow>
					<h3>Gift vouchers sit inside the same customer flow.</h3>
					<p>Customers can buy vouchers online without the owner needing to manually arrange the purchase at the moment interest appears.</p>
				</div>
				<figure class="jas-shot jas-shot--dark">
					<div class="jas-shot__chrome" aria-hidden="true">
						<span></span>
						<span></span>
						<span></span>
						<div></div>
					</div>
					<div class="jas-shot__screen">
						<img
							src="/images/case-studies/jas-school-of-spice/jas-school-of-spice-gift-voucher-page.png"
							alt="Jas's School of Spice gift voucher page showing online voucher purchase options."
							width="936"
							height="991"
							loading="eager"
							fetchpriority="high"
						/>
					</div>
					<figcaption>Gift voucher page</figcaption>
				</figure>
			</div>
			<div class="case-dark-feature">
				<div>
					<Eyebrow tone="dark">Owner control</Eyebrow>
					<h3>The public booking journey is only one part of the system.</h3>
					<p>Behind it sits protected operational control for class dates, booking visibility, booking changes, voucher handling and customer communication.</p>
				</div>
				<figure class="jas-shot jas-shot--dark">
					<div class="jas-shot__chrome" aria-hidden="true">
						<span></span>
						<span></span>
						<span></span>
						<div></div>
					</div>
					<div class="jas-shot__screen">
						<img
							src="/images/case-studies/jas-school-of-spice/jas-school-of-spice-ops-class-dates.png"
							alt="Protected operations screen for Jas's School of Spice class dates and availability."
							width="1280"
							height="812"
							loading="eager"
							fetchpriority="high"
						/>
					</div>
					<figcaption>Class date controls</figcaption>
				</figure>
			</div>
		</div>
	</section>

	<section class="ka-section ka-section-white case-results">
		<div class="ka-wrap">
			<div class="case-results__grid">
				<div>
					<SectionHeading
						eyebrow="Owner view"
						title="More of the repeated booking work is handled when the customer is ready."
						highlight="when the customer is ready."
					/>
					<div class="case-copy">
						<p>Before this system, enquiries and bookings depended on manual back and forth. A customer could be interested in a class, but the booking still relied on messages being answered, availability being checked and payment being arranged at the right moment.</p>
						<p>Now a customer can find the class, book a place and pay while the interest is there. Gift vouchers can be bought online, and Jas receives Telegram alerts when a booking or enquiry lands.</p>
						<p>The system works as a practical business system tied to how the cookery school actually operates.</p>
					</div>
				</div>
				<article class="case-review">
					<p class="case-stars" aria-label="Five star review">*****</p>
					<blockquote>I cannot recommend Zax highly enough. He exceeded my expectations in every way and genuinely went above and beyond throughout the entire process. From the very beginning, he took the time to fully understand my business and clearly explained exactly what I would be getting. The new booking system has transformed how my business operates, making it much easier for customers to book classes and purchase gift vouchers online. Most importantly, the system has freed up a significant amount of my time. Instead of spending hours answering the same questions and responding to enquiries, I can focus on the parts of my business that I truly enjoy. Because the system works 24/7, customers can get the information they need and make bookings at any time, meaning I no longer lose potential customers who might otherwise have moved on while waiting for a reply. I was thoroughly supported throughout the setup and handover process, and nothing ever felt too much trouble.</blockquote>
					<footer>Jas Dhillon, Jas's School of Spice</footer>
				</article>
			</div>
		</div>
	</section>

	<section class="ka-section ka-section-deep case-cta">
		<div class="ka-wrap">
			<div class="case-cta__inner">
				<Eyebrow>Start here</Eyebrow>
				<h2>Want to find the right first system for your business?</h2>
				<p>The Business AI Blueprint is a focused paid review that helps identify where AI can create real value, what system is worth building first, and whether there is a clear business case before a larger build.</p>
				<ButtonPrimary href="/blueprint" label="Start with the Business AI Blueprint" data-plausible="BookACall" />
			</div>
		</div>
	</section>
</Layout>

<style>
	.case-hero {
		background:
			linear-gradient(100deg, rgba(8, 20, 40, 0.98) 22%, rgba(8, 20, 40, 0.76) 62%, rgba(8, 20, 40, 0.98) 100%),
			radial-gradient(circle at 80% 24%, rgba(0, 183, 198, 0.22), transparent 34%),
			var(--navy-deep);
		border-bottom: 1px solid var(--line-dark);
		color: var(--white);
	}

	.case-hero__grid {
		display: grid;
		grid-template-columns: 1fr 0.75fr;
		gap: 64px;
		align-items: end;
		padding: 116px 0 132px;
	}

	.case-hero h1 {
		max-width: 13ch;
		margin: 0 0 24px;
		color: var(--white);
		font-size: clamp(46px, 6vw, 76px);
		font-weight: 500;
	}

	.case-hero p {
		max-width: 54ch;
		color: var(--body-light);
		font-size: 18px;
		line-height: 1.66;
	}

	.case-hero__panel {
		padding: 30px;
		border: 1px solid var(--line-dark);
		border-radius: 16px;
		background: rgba(255, 255, 255, 0.05);
		text-align: left;
	}

	.case-hero__panel span {
		color: var(--teal-soft);
		font-family: "JetBrains Mono", ui-monospace, SFMono-Regular, Menlo, monospace;
		font-size: 11px;
		letter-spacing: 0.12em;
		text-transform: uppercase;
	}

	.case-hero__panel strong {
		display: block;
		margin-top: 14px;
		color: var(--gold-soft);
		font-family: "Fraunces", Georgia, serif;
		font-size: clamp(28px, 3vw, 42px);
		font-weight: 600;
		line-height: 1.08;
	}

	.case-context {
		background: var(--navy);
		border-bottom: 1px solid var(--line-dark);
	}

	.case-context .case-copy {
		color: var(--body-light);
	}

	.case-two-col,
	.case-built-grid,
	.case-results__grid,
	.case-dark-feature {
		display: grid;
		grid-template-columns: 0.9fr 1.1fr;
		gap: 64px;
		align-items: start;
	}

	.case-copy {
		display: grid;
		gap: 18px;
		max-width: 58ch;
		color: var(--body);
		font-size: 17px;
		line-height: 1.68;
		text-align: left;
	}

	.case-feature-list {
		display: grid;
		grid-template-columns: 1fr;
		gap: 0;
		margin: 34px 0 0;
		padding: 22px;
		border: 1px solid var(--line-light);
		border-radius: 14px;
		background: var(--white);
		box-shadow: 0 24px 54px -46px rgba(11, 18, 32, 0.32);
	}

	.case-feature-list article {
		padding: 18px 0;
		border-top: 1px solid var(--line-light);
		text-align: left;
	}

	.case-feature-list article:first-child {
		padding-top: 0;
		border-top: 0;
	}

	.case-feature-list article:last-child {
		padding-bottom: 0;
	}

	.case-feature-list h3 {
		margin: 0 0 14px;
		color: var(--ink);
		font-size: 20px;
		font-weight: 600;
	}

	.case-feature-list ul {
		display: grid;
		gap: 11px;
		margin: 0;
		padding: 0;
		list-style: none;
	}

	.case-feature-list li {
		display: grid;
		grid-template-columns: 16px 1fr;
		gap: 12px;
		color: var(--body);
		font-size: 15px;
		line-height: 1.55;
	}

	.case-feature-list span {
		width: 8px;
		height: 8px;
		margin-top: 0.62em;
		border-radius: 999px;
		background: var(--teal);
	}

	.case-frame-stack {
		display: grid;
		gap: 22px;
	}

	.jas-shot {
		margin: 0;
	}

	.jas-shot__chrome {
		display: flex;
		align-items: center;
		gap: 6px;
		padding: 10px 12px;
		border: 1px solid var(--line-light);
		border-bottom: 0;
		border-radius: 13px 13px 0 0;
		background: var(--white);
	}

	.jas-shot--dark .jas-shot__chrome {
		border-color: rgba(255, 255, 255, 0.16);
		background: #f8fafc;
	}

	.jas-shot__chrome span {
		width: 9px;
		height: 9px;
		border-radius: 999px;
		background: #d8e0ea;
	}

	.jas-shot__chrome div {
		height: 8px;
		flex: 1;
		max-width: 180px;
		margin-left: 10px;
		border-radius: 999px;
		background: #eef3f7;
	}

	.jas-shot__chrome strong {
		padding: 5px 8px;
		border-radius: 5px;
		background: rgba(7, 17, 31, 0.72);
		color: var(--teal-soft);
		font-family: "JetBrains Mono", ui-monospace, SFMono-Regular, Menlo, monospace;
		font-size: 10px;
		font-weight: 500;
		letter-spacing: 0.08em;
		line-height: 1;
		text-transform: uppercase;
	}

	.jas-shot__screen {
		border: 1px solid var(--line-light);
		border-radius: 0 0 13px 13px;
		background: #f6f9fc;
		box-shadow: 0 30px 58px -34px rgba(11, 18, 32, 0.38);
	}

	.jas-shot--dark .jas-shot__screen {
		border-color: rgba(255, 255, 255, 0.16);
		box-shadow: 0 30px 58px -34px rgba(0, 0, 0, 0.62);
	}

	.jas-shot__screen img {
		display: block;
		width: 100%;
		max-width: 100%;
		height: auto;
		object-fit: contain;
		object-position: top center;
		position: static;
		opacity: 1;
		filter: none;
	}

	.jas-shot figcaption {
		margin-top: 9px;
		color: #7c8b9c;
		font-family: "JetBrains Mono", ui-monospace, SFMono-Regular, Menlo, monospace;
		font-size: 11px;
		line-height: 1.5;
		text-align: left;
	}

	.jas-shot--dark figcaption {
		color: var(--body-light);
	}

	.case-flow-band {
		position: relative;
		overflow: hidden;
		border-top: 1px solid var(--line-dark);
		border-bottom: 1px solid var(--line-dark);
		background: var(--navy-deep);
	}

	.case-flow-band::before {
		content: "";
		position: absolute;
		inset: auto -8% -30% 48%;
		height: 520px;
		background: radial-gradient(circle, rgba(0, 183, 198, 0.14), transparent 68%);
		pointer-events: none;
	}

	.jas-flow {
		position: relative;
		z-index: 2;
		display: grid;
		grid-template-columns: repeat(3, minmax(0, 1fr));
		gap: 18px;
		margin-top: 58px;
	}

	.jas-flow__phase {
		position: relative;
		padding: 24px;
		border: 1px solid var(--line-dark);
		border-radius: 16px;
		background: rgba(255, 255, 255, 0.04);
		text-align: left;
	}

	.jas-flow__phase-head {
		padding-bottom: 20px;
		border-bottom: 1px solid var(--line-dark);
	}

	.jas-flow__phase-head span {
		display: inline-flex;
		margin-bottom: 12px;
		color: var(--gold-soft);
		font-family: "JetBrains Mono", ui-monospace, SFMono-Regular, Menlo, monospace;
		font-size: 11px;
		letter-spacing: 0.12em;
		text-transform: uppercase;
	}

	.jas-flow__phase-head p,
	.case-dark-feature p {
		color: var(--body-light);
		font-size: 15px;
		line-height: 1.62;
	}

	.jas-flow ol {
		display: grid;
		gap: 14px;
		margin: 20px 0 0;
		padding: 0;
		list-style: none;
	}

	.jas-flow li {
		display: grid;
		grid-template-columns: 38px 1fr;
		gap: 12px;
		align-items: start;
	}

	.jas-flow strong {
		display: inline-flex;
		width: 34px;
		height: 34px;
		align-items: center;
		justify-content: center;
		border: 1px solid rgba(63, 216, 227, 0.34);
		border-radius: 9px;
		background: rgba(0, 183, 198, 0.1);
		color: var(--teal-soft);
		font-family: "JetBrains Mono", ui-monospace, SFMono-Regular, Menlo, monospace;
		font-size: 11px;
		font-weight: 600;
	}

	.jas-flow li p {
		color: var(--white);
		font-size: 15px;
		line-height: 1.5;
	}

	.case-dark-feature {
		position: relative;
		z-index: 2;
		margin-top: 64px;
		padding-top: 46px;
		border-top: 1px solid var(--line-dark);
	}

	.case-dark-feature h3 {
		max-width: 16ch;
		margin: 0 0 16px;
		color: var(--white);
		font-size: clamp(30px, 4vw, 44px);
		font-weight: 500;
	}

	.case-review,
	.case-cta__inner {
		border: 1px solid var(--line-light);
		border-radius: 16px;
		background: var(--white);
		box-shadow: 0 28px 58px -48px rgba(11, 18, 32, 0.28);
		text-align: left;
	}

	.case-review {
		padding: 30px;
	}

	.case-stars {
		margin-bottom: 16px;
		color: #fbbc05;
		font-size: 16px;
		letter-spacing: 2px;
	}

	.case-review blockquote {
		margin: 0;
		color: var(--body);
		font-size: 16px;
		font-style: italic;
		line-height: 1.66;
	}

	.case-review footer {
		margin-top: 20px;
		color: var(--teal-deep);
		font-size: 14px;
		font-weight: 700;
	}

	.case-cta__inner {
		max-width: 56ch;
		padding: 34px;
		border-color: var(--line-dark);
		background: rgba(255, 255, 255, 0.04);
		box-shadow: none;
	}

	.case-cta h2 {
		margin: 0 0 18px;
		color: var(--white);
		font-size: clamp(30px, 4vw, 44px);
		font-weight: 500;
	}

	.case-cta p {
		margin-bottom: 28px;
		color: var(--body-light);
		font-size: 16px;
		line-height: 1.66;
	}

	.case-cta :global(.ka-eyebrow--light) {
		color: var(--teal-soft);
	}

	.case-cta :global(.ka-eyebrow--light)::before {
		background: var(--gold-soft);
	}

	@media (max-width: 960px) {
		.jas-flow {
			grid-template-columns: 1fr;
		}
	}

	@media (max-width: 860px) {
		.case-hero__grid,
		.case-two-col,
		.case-built-grid,
		.case-results__grid,
		.case-dark-feature,
		.case-feature-list {
			grid-template-columns: 1fr;
		}
	}

	@media (max-width: 640px) {
		.case-hero__grid {
			padding: 78px 0 92px;
		}

		.jas-flow {
			grid-template-columns: 1fr;
		}

		.case-hero__panel,
		.jas-flow article,
		.case-review,
		.case-cta__inner {
			padding: 22px;
		}
	}
</style>
