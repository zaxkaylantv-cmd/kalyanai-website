---
import ButtonPrimary from '../components/ButtonPrimary.astro';
import CTASection from '../components/CTASection.astro';
import Eyebrow from '../components/Eyebrow.astro';
import Layout from '../layouts/Layout.astro';
import SectionHeading from '../components/SectionHeading.astro';

const calendlyUrl = 'https://calendly.com/zaxkalyan/new-meeting';

const firstSystemPrinciples = [
	{
		label: '01',
		title: 'It should solve a real business problem.',
		copy: 'The recommendation should be tied to a real operational pressure, not an AI idea looking for somewhere to fit.',
	},
	{
		label: '02',
		title: 'It should fit the way your team already works.',
		copy: 'The best first system should support the way the business already runs, rather than forcing people into a completely new process.',
	},
	{
		label: '03',
		title: 'It should have a clear reason to exist before anything is built.',
		copy: 'Before build work starts, there should be a clear business reason, expected value, and practical use case.',
	},
];

const deliverables = [
	'A 30 minute discovery and operations diagnostic.',
	'A 30 minute blueprint presentation.',
	'A diagnostic view of your current way of working, tools, bottlenecks and manual pressure points.',
	'A clear map of where AI can create the most value in your business.',
	'A recommended first system to build, with a clear reason why.',
	'A practical value view, so you can see where the return can come from.',
	'A written blueprint you keep, specific to your business and not a generic template.',
];

---

<Layout
	title="Business AI Blueprint | Find Where AI Earns Its Keep"
	description="A focused paid review showing where AI can make your business easier to run, control and grow, and what system is worth building first."
	showFinalCta={false}
>
	<section class="blueprint-hero">
		<div class="ka-wrap">
			<div class="blueprint-hero__inner">
				<Eyebrow tone="dark">Focused paid review</Eyebrow>
				<h1>Business AI Blueprint</h1>
				<p class="blueprint-hero__core">Find where AI earns its keep in your business.</p>
				<p class="blueprint-hero__copy">A focused diagnostic showing where AI can make your business easier to run, control and grow, what system would be worth building first, and where the return can come from.</p>
				<ButtonPrimary href={calendlyUrl} label="Start with the Blueprint" data-plausible="BookACall" />
			</div>
		</div>
	</section>

	<section class="ka-section ka-section-dark blueprint-owners">
		<div class="ka-wrap">
			<div class="blueprint-two-col">
				<SectionHeading
					eyebrow="Why owners book a Blueprint"
					title="AI matters. The hard part is knowing where it belongs."
					highlight="where it belongs."
					tone="dark"
				/>
				<div class="blueprint-copy-stack">
					<p>Most business owners can see that AI could help, but they are not always clear where it fits, what would be worth building first, or whether the return would justify the investment.</p>
					<p>The Business AI Blueprint looks at how your business actually runs, where time is being lost, where decisions are being made without the full picture, and where the right AI system could create real value.</p>
					<p>It also helps identify what not to build yet, so effort and spend are not pulled toward something impressive that does not become useful.</p>
				</div>
			</div>
		</div>
	</section>

	<section class="ka-section ka-section-dark blueprint-start">
		<div class="ka-wrap">
			<div class="blueprint-two-col blueprint-two-col--reverse">
				<div class="blueprint-callout">
					<p>Start with clarity before committing to a larger system.</p>
				</div>
				<div>
					<SectionHeading
						eyebrow="Why we start here"
						title="The Blueprint is a practical first step before you spend on the wrong thing."
						highlight="before you spend on the wrong thing."
						lead="We do not start by selling a fixed product. Every business works differently, so the first step is to understand how yours actually runs."
						tone="dark"
					/>
					<div class="blueprint-copy-stack blueprint-copy-stack--compact">
						<p>The Blueprint gives you clear, practical direction before committing to a larger AI system build.</p>
						<p>You do not need to know what system you need before we speak. That is the point of the Blueprint.</p>
					</div>
				</div>
			</div>
		</div>
	</section>

	<section class="ka-section ka-section-white blueprint-deliverables">
		<div class="ka-wrap">
			<div class="blueprint-two-col">
				<SectionHeading
					eyebrow="What you get"
					title="A clear view of what is worth building first."
					highlight="worth building first."
					lead="The output is specific to your business, not a generic template or a list of tools."
				/>
				<ul class="blueprint-checklist">
					{deliverables.map((item) => (
						<li>
							<span aria-hidden="true">✓</span>
							<p>{item}</p>
						</li>
					))}
				</ul>
			</div>
		</div>
	</section>

	<section class="ka-section ka-section-deep blueprint-system">
		<div class="ka-wrap">
			<SectionHeading
				eyebrow="The right first system"
				title="A useful first system has to earn its place."
				lead="The recommendation should be practical, specific to the business, and clear enough to justify build work before anything is started."
				tone="dark"
			/>
			<div class="blueprint-principles">
				{firstSystemPrinciples.map((principle, index) => (
					<article class:list={['blueprint-principle', index === 0 && 'blueprint-principle--wide']}>
						<p>{principle.label}</p>
						<h3>{principle.title}</h3>
						<span>{principle.copy}</span>
					</article>
				))}
			</div>
		</div>
	</section>

	<CTASection
		eyebrow="Ready to see where AI fits?"
		title="Book your Business AI Blueprint."
		copy="After the Blueprint, you will have a clear view of where AI can help your business and what system would be worth building first. There is no obligation to continue."
		href={calendlyUrl}
		label="Book your Business AI Blueprint"
	/>
</Layout>

<style>
	.blueprint-hero {
		background:
			linear-gradient(100deg, rgba(8, 20, 40, 0.98) 20%, rgba(8, 20, 40, 0.78) 60%, rgba(8, 20, 40, 0.98) 100%),
			radial-gradient(circle at 78% 24%, rgba(0, 183, 198, 0.23), transparent 36%),
			var(--navy-deep);
		border-bottom: 1px solid var(--line-dark);
		color: var(--white);
	}

	.blueprint-hero__inner {
		max-width: 860px;
		padding: 116px 0 132px;
		text-align: left;
	}

	.blueprint-hero h1 {
		max-width: 14ch;
		margin: 0 0 24px;
		color: var(--white);
		font-size: clamp(48px, 6vw, 78px);
		font-weight: 500;
	}

	.blueprint-hero__core {
		max-width: 24ch;
		margin-bottom: 18px;
		color: var(--gold-soft);
		font-family: "Fraunces", Georgia, serif;
		font-size: clamp(26px, 3vw, 36px);
		font-weight: 500;
		line-height: 1.12;
	}

	.blueprint-hero__copy {
		max-width: 52ch;
		margin-bottom: 34px;
		color: var(--body-light);
		font-size: 18px;
		line-height: 1.66;
	}

	.blueprint-two-col {
		display: grid;
		grid-template-columns: 0.9fr 1.1fr;
		gap: 64px;
		align-items: start;
	}

	.blueprint-two-col--reverse {
		grid-template-columns: 0.85fr 1.15fr;
	}

	.blueprint-copy-stack {
		display: grid;
		gap: 18px;
		max-width: 58ch;
		color: var(--body-light);
		font-size: 17px;
		line-height: 1.68;
		text-align: left;
	}

	.blueprint-copy-stack--compact {
		margin-top: 22px;
	}

	.blueprint-callout {
		padding: 34px;
		border: 1px solid var(--line-dark);
		border-radius: 16px;
		background: linear-gradient(135deg, rgba(0, 183, 198, 0.12), rgba(255, 255, 255, 0.04) 62%);
	}

	.blueprint-callout p {
		max-width: 14ch;
		color: var(--white);
		font-family: "Fraunces", Georgia, serif;
		font-size: clamp(30px, 4vw, 44px);
		font-weight: 500;
		line-height: 1.08;
	}

	.blueprint-owners {
		background: var(--navy);
		border-bottom: 1px solid var(--line-dark);
	}

	.blueprint-start {
		background: var(--navy-2);
		border-bottom: 1px solid var(--line-dark);
	}

	.blueprint-system {
		position: relative;
		overflow: hidden;
		border-bottom: 1px solid var(--line-dark);
		background: var(--navy-deep);
	}

	.blueprint-system::before {
		content: "";
		position: absolute;
		inset: auto -8% -28% 45%;
		height: 520px;
		background: radial-gradient(circle, rgba(0, 183, 198, 0.14), transparent 68%);
		pointer-events: none;
	}

	.blueprint-principles {
		position: relative;
		z-index: 2;
		display: grid;
		grid-template-columns: 1fr 1fr;
		gap: 18px;
		margin-top: 58px;
	}

	.blueprint-principle {
		padding: 28px;
		border: 1px solid var(--line-dark);
		border-radius: 16px;
		background: rgba(255, 255, 255, 0.04);
		text-align: left;
	}

	.blueprint-principle--wide {
		display: grid;
		grid-column: span 2;
		grid-template-columns: 1fr;
		gap: 28px;
		align-items: start;
		background: linear-gradient(135deg, rgba(0, 183, 198, 0.13), rgba(255, 255, 255, 0.04) 58%);
	}

	.blueprint-principle p {
		margin-bottom: 14px;
		color: var(--gold-soft);
		font-family: "JetBrains Mono", ui-monospace, SFMono-Regular, Menlo, monospace;
		font-size: 18px;
		font-weight: 500;
		letter-spacing: 0.14em;
		text-transform: uppercase;
	}

	.blueprint-principle h3 {
		margin: 0 0 10px;
		color: var(--white);
		font-size: 25px;
		font-weight: 600;
	}

	.blueprint-principle span {
		display: block;
		color: var(--body-light);
		font-size: 15px;
		line-height: 1.62;
	}

	.blueprint-checklist {
		display: grid;
		grid-template-columns: 1fr 1fr;
		gap: 14px;
		margin: 0;
		padding: 0;
		list-style: none;
	}

	.blueprint-checklist li {
		display: grid;
		grid-template-columns: 28px 1fr;
		gap: 13px;
		align-items: start;
		padding: 20px;
		border: 1px solid var(--line-light);
		border-radius: 14px;
		background: var(--white);
		box-shadow: 0 24px 54px -46px rgba(11, 18, 32, 0.24);
	}

	.blueprint-checklist span {
		display: flex;
		width: 26px;
		height: 26px;
		align-items: center;
		justify-content: center;
		border-radius: 999px;
		background: rgba(0, 183, 198, 0.12);
		color: var(--teal-deep);
		font-size: 14px;
		font-weight: 700;
	}

	.blueprint-checklist p {
		color: var(--body);
		font-size: 15px;
		line-height: 1.58;
	}

	.blueprint-deliverables {
		border-bottom: 1px solid var(--line-light);
	}

	:global(.ka-final-cta) {
		background: var(--paper);
		border-top: 1px solid var(--line-light);
		color: var(--ink);
	}

	:global(.ka-final-cta h2) {
		color: var(--ink) !important;
	}

	:global(.ka-final-cta p) {
		color: var(--body) !important;
	}

	@media (max-width: 860px) {
		.blueprint-two-col,
		.blueprint-two-col--reverse,
		.blueprint-principles,
		.blueprint-principle--wide,
		.blueprint-checklist,
		.blueprint-proof__grid {
			grid-template-columns: 1fr;
		}

		.blueprint-principle--wide {
			grid-column: auto;
		}
	}

	@media (max-width: 640px) {
		.blueprint-hero__inner {
			padding: 78px 0 92px;
		}

		.blueprint-callout,
		.blueprint-principle,
		.blueprint-proof__lead,
		.blueprint-proof__stack article {
			padding: 22px;
		}
	}
</style>
