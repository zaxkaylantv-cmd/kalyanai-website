---
import ButtonGhost from '../components/ButtonGhost.astro';
import ButtonPrimary from '../components/ButtonPrimary.astro';
import CTASection from '../components/CTASection.astro';
import Eyebrow from '../components/Eyebrow.astro';
import Frame from '../components/Frame.astro';
import HomepageHero from '../components/HomepageHero.astro';
import Layout from '../layouts/Layout.astro';
import ProcessFlow from '../components/ProcessFlow.astro';
import SectionHeading from '../components/SectionHeading.astro';
import TestimonialCard from '../components/TestimonialCard.astro';

const trustItems = [
	{ lead: 'Real systems', rest: 'running live today' },
	{ lead: 'Production grade', rest: 'not demos' },
	{ lead: 'Supported', rest: 'after delivery' },
	{ lead: 'Built around', rest: 'how your business works' },
];

const approachItems = [
	{
		tag: 'Run',
		title: 'Easier to operate, day to day.',
		copy: 'Fewer loose ends and less repeated manual work, with clearer structure around how the business runs.',
	},
	{
		tag: 'Control',
		title: 'Clearer visibility and ownership.',
		copy: 'You see what is happening and where decisions are needed. Control stays with you, not the system.',
	},
	{
		tag: 'Grow',
		title: 'A stronger position to build from.',
		copy: 'More capacity, better follow through and clearer reporting, so the business is set up for progress.',
	},
];

const processSteps = [
	{
		title: 'Blueprint',
		copy: 'Find where AI can create value and whether there is a clear business case.',
	},
	{
		title: 'Build',
		copy: 'Create the right system around the way the business actually works.',
	},
	{
		title: 'Deploy',
		copy: 'Put it into real use with sensible checks, testing and a proper handover.',
	},
	{
		title: 'Support',
		copy: 'Stay involved after delivery so the system keeps working over time.',
	},
];
---

<Layout
	title="Kalyan AI | AI Systems That Make Business Easier to Run, Control and Grow"
	description="Kalyan AI builds practical AI systems around how your business actually works, helping owners gain clarity, control and a better first step with AI."
	showFinalCta={false}
>
	<HomepageHero />

	<section class="ka-trust-strip" aria-label="Kalyan AI proof points">
		<div class="ka-wrap">
			<div class="ka-trust-strip__inner">
				{trustItems.map((item) => (
					<p><strong>{item.lead}</strong>{item.lead === 'Production grade' ? ', ' : ' '}{item.rest}</p>
				))}
			</div>
		</div>
	</section>

	<section class="ka-section ka-section-dark ka-approach">
		<div class="ka-wrap">
			<div class="ka-approach__grid">
				<div>
					<Eyebrow>The approach</Eyebrow>
					<h2>The starting point is your business, <span>not the tool.</span></h2>
				</div>
				<div>
					<p class="ka-approach__lead">
						AI is everywhere now, but doing something with AI is not the same as doing the right thing. We start by understanding how your business actually runs, then find where a system would earn its keep. Whatever shape your business is in, there is usually value worth building toward.
					</p>
					<div class="ka-approach__points">
						{approachItems.map((item) => (
							<article>
								<p>{item.tag}</p>
								<h3>{item.title}</h3>
								<span>{item.copy}</span>
							</article>
						))}
					</div>
				</div>
			</div>
		</div>
	</section>

	<section class="ka-section ka-section-white ka-proof">
		<div class="ka-wrap">
			<SectionHeading
				eyebrow="Real systems, not slides"
				title="See what this looks like in practice."
				highlight="in practice."
				lead="Each system below was built, hosted and supported by Kalyan AI, shaped around how a real business works. No templates, no generic tools."
				class="ka-proof__heading"
			/>

			<div class="ka-proof__item">
				<div class="ka-proof__copy">
					<p class="ka-proof__sector">Finance operations</p>
					<h3>Spa by Kaajal</h3>
					<div class="ka-proof__stat" aria-label="Weekly finance admin reduced from around 4 to 6 hours a week to around 30 minutes">
						<span class="ka-proof__from">4-6 hrs</span>
						<span class="ka-proof__to">30 min</span>
						<span class="ka-proof__unit">weekly admin, after launch</span>
					</div>
					<p>
						A finance and visibility system that brought invoices, receipts and accountant ready exports into one place, with the owner in clear control of what matters.
					</p>
					<ButtonGhost href="/case-studies/spa-by-kaajal" label="Read the case study" />
				</div>
				<Frame
					src="/images/case-studies/after-dashboard.png"
					alt="Spa by Kaajal finance dashboard showing invoices, receipts, cashflow, tips and overdue items in one place."
					loading="eager"
				/>
			</div>

			<div class="ka-proof__item ka-proof__item--flip">
				<div class="ka-proof__copy">
					<p class="ka-proof__sector">Bookings and operations</p>
					<h3>Jas's School of Spice</h3>
					<p>
						A live booking and operations system: customers book and pay online and the owner keeps clear control behind the scenes, with the whole operation running on one system.
					</p>
					<ButtonGhost href="/case-studies/jas-school-of-spice/" label="Read the case study" />
				</div>
				<Frame
					src="/images/case-studies/jas-school-of-spice/jas-school-of-spice-customer-homepage.png"
					alt="Jas's School of Spice customer homepage showing class booking options."
					imageFit="contain"
					loading="eager"
				/>
			</div>

			<div class="ka-proof__item">
				<div class="ka-proof__copy">
					<p class="ka-proof__sector">Kalyan AI, internal</p>
					<h3>Internal Operating Stack</h3>
					<p>
						The system Kalyan AI runs its own business on, bringing commercial activity, follow through, visibility and system health together in one controlled place. The same thinking, applied to ourselves.
					</p>
					<ButtonGhost href="/case-studies/kalyan-ai-internal-stack/" label="Read the case study" />
				</div>
				<Frame
					src="/images/case-studies/kalyan-ai-internal-stack/kalyan-ai-internal-operating-dashboard.png"
					alt="Kalyan AI internal operating dashboard showing business activity and system health."
					imageFit="contain"
					loading="eager"
				/>
			</div>
		</div>
	</section>

	<section class="ka-section ka-section-dark ka-reviews">
		<div class="ka-wrap">
			<div class="ka-reviews__heading">
				<Eyebrow tone="dark">In their words</Eyebrow>
				<h2>What owners say after the system is live.</h2>
				<p class="ka-reviews__verified">
					<svg viewBox="0 0 48 48" aria-label="Google">
						<path fill="#4285F4" d="M45.12 24.5c0-1.56-.14-3.06-.4-4.5H24v8.51h11.84c-.51 2.75-2.06 5.08-4.39 6.64v5.52h7.11c4.16-3.83 6.56-9.47 6.56-16.17z"></path>
						<path fill="#34A853" d="M24 46c5.94 0 10.92-1.97 14.56-5.33l-7.11-5.52c-1.97 1.32-4.49 2.1-7.45 2.1-5.73 0-10.58-3.87-12.31-9.07H4.34v5.7C7.96 41.07 15.4 46 24 46z"></path>
						<path fill="#FBBC05" d="M11.69 28.18C11.25 26.86 11 25.45 11 24s.25-2.86.69-4.18v-5.7H4.34C2.85 17.09 2 20.45 2 24s.85 6.91 2.34 9.88l7.35-5.7z"></path>
						<path fill="#EA4335" d="M24 10.75c3.23 0 6.13 1.11 8.41 3.29l6.31-6.31C34.91 4.18 29.93 2 24 2 15.4 2 7.96 6.93 4.34 14.12l7.35 5.7c1.73-5.2 6.58-9.07 12.31-9.07z"></path>
					</svg>
					Verified on the Kalyan AI Google Business Profile
				</p>
			</div>
			<div class="ka-reviews__grid">
				<TestimonialCard
					name="Kaajal Malik"
					business="Spa by Kaajal"
					initial="K"
					quote="I was spending 4 to 6 hours a week on finance admin. Zax took the time to understand how my salon works and built a system around it. Now everything is in one place, I know what's going on, and getting things ready for my accountant is so much easier. He made sure I was comfortable using it and was always available when I had questions."
				/>
				<TestimonialCard
					name="Jas"
					business="Jas's School of Spice"
					initial="J"
					variant="green"
					quote="Zax took the time to fully understand my business and clearly explained exactly what I would be getting. The new booking system has transformed how my business operates, making it much easier for customers to book classes and purchase gift vouchers online. I was thoroughly supported throughout the setup and handover process, and nothing ever felt too much trouble."
				/>
			</div>
		</div>
	</section>

	<section class="ka-section ka-section-deep ka-process">
		<div class="ka-wrap">
			<SectionHeading
				eyebrow="How we work"
				title="From a clear starting point to a working system."
				lead="A controlled path from first conversation to a system that keeps working in real conditions."
				tone="dark"
			/>
			<ProcessFlow steps={processSteps} />
		</div>
	</section>

	<CTASection />
</Layout>

<style>
	.ka-trust-strip {
		background: var(--navy-2);
		border-top: 1px solid var(--line-dark);
		border-bottom: 1px solid var(--line-dark);
	}

	.ka-trust-strip__inner {
		display: flex;
		flex-wrap: wrap;
		justify-content: space-between;
		gap: 18px 40px;
		padding: 26px 0;
	}

	.ka-trust-strip p {
		color: var(--white);
		font-size: 14px;
		line-height: 1.5;
	}

	.ka-trust-strip strong {
		color: var(--gold-soft);
		font-weight: 700;
	}

	.ka-approach {
		background: var(--navy);
		border-bottom: 1px solid var(--line-dark);
		color: var(--white);
	}

	.ka-approach__grid {
		display: grid;
		grid-template-columns: 0.85fr 1fr;
		gap: 60px;
		align-items: start;
	}

	.ka-approach h2 {
		max-width: 20ch;
		margin: 0;
		color: var(--white);
		font-size: clamp(30px, 3.7vw, 42px);
		font-weight: 500;
	}

	.ka-approach h2 span {
		color: var(--teal-soft);
	}

	.ka-approach__lead {
		max-width: 50ch;
		margin-bottom: 36px;
		color: var(--body-light);
		font-size: 17px;
		line-height: 1.62;
	}

	.ka-approach__points {
		display: flex;
		flex-direction: column;
	}

	.ka-approach article {
		padding: 26px 0;
		border-top: 1px solid var(--line-dark);
		text-align: left;
	}

	.ka-approach article:last-child {
		border-bottom: 1px solid var(--line-dark);
	}

	.ka-approach article p {
		margin-bottom: 10px;
		color: var(--teal-soft);
		font-family: "JetBrains Mono", ui-monospace, SFMono-Regular, Menlo, monospace;
		font-size: 11px;
		font-weight: 500;
		letter-spacing: 0.14em;
		text-transform: uppercase;
	}

	.ka-approach article h3 {
		margin: 0 0 7px;
		color: var(--white);
		font-size: 20px;
		font-weight: 600;
	}

	.ka-approach article span {
		display: block;
		max-width: 46ch;
		color: var(--body-light);
		font-size: 15px;
		line-height: 1.6;
	}

	.ka-proof__heading {
		margin-bottom: 76px;
	}

	.ka-proof__item {
		display: grid;
		grid-template-columns: 1fr 1fr;
		gap: 54px;
		align-items: center;
		margin-bottom: 104px;
	}

	.ka-proof__item:last-child {
		margin-bottom: 0;
	}

	.ka-proof__item--flip .ka-proof__copy {
		order: 2;
	}

	.ka-proof__copy {
		text-align: left;
	}

	.ka-proof__sector {
		margin-bottom: 13px;
		color: var(--teal-deep);
		font-family: "JetBrains Mono", ui-monospace, SFMono-Regular, Menlo, monospace;
		font-size: 11px;
		font-weight: 500;
		letter-spacing: 0.09em;
		text-transform: uppercase;
	}

	.ka-proof h3 {
		margin: 0 0 14px;
		color: var(--ink);
		font-size: 26px;
		font-weight: 600;
	}

	.ka-proof__copy > p:not(.ka-proof__sector) {
		max-width: 44ch;
		margin-bottom: 20px;
		color: var(--body);
		font-size: 15.5px;
		line-height: 1.65;
	}

	.ka-proof__stat {
		display: flex;
		align-items: baseline;
		flex-wrap: wrap;
		gap: 9px 13px;
		margin-bottom: 20px;
	}

	.ka-proof__from {
		color: #8a9aac;
		font-family: "Fraunces", Georgia, serif;
		font-size: 23px;
		text-decoration: line-through;
		text-decoration-color: rgba(138, 154, 172, 0.55);
	}

	.ka-proof__to {
		color: var(--gold);
		font-family: "Fraunces", Georgia, serif;
		font-size: 40px;
		font-weight: 700;
		line-height: 1;
	}

	.ka-proof__unit {
		color: var(--body);
		font-size: 13.5px;
	}

	.ka-reviews h2 {
		max-width: 19ch;
		margin: 0 0 14px;
		color: var(--white);
		font-size: clamp(30px, 3.7vw, 42px);
		font-weight: 500;
	}

	.ka-reviews__verified {
		display: inline-flex;
		align-items: center;
		gap: 9px;
		margin-bottom: 40px;
		color: var(--body-light);
		font-size: 14px;
	}

	.ka-reviews__verified svg {
		width: 17px;
		height: 17px;
		flex: 0 0 auto;
	}

	.ka-reviews__grid {
		display: grid;
		grid-template-columns: 1fr 1fr;
		gap: 24px;
	}

	.ka-reviews {
		background: var(--navy-2);
		border-top: 1px solid var(--line-dark);
	}

	.ka-process {
		border-top: 1px solid var(--line-dark);
	}

	@media (max-width: 860px) {
		.ka-approach__grid,
		.ka-proof__item {
			grid-template-columns: 1fr;
		}

		.ka-approach__grid {
			gap: 34px;
		}

		.ka-proof__item {
			gap: 28px;
			margin-bottom: 78px;
		}

		.ka-proof__item--flip .ka-proof__copy {
			order: 0;
		}
	}

	@media (max-width: 760px) {
		.ka-reviews__grid {
			grid-template-columns: 1fr;
		}
	}

	@media (max-width: 640px) {
		.ka-trust-strip__inner {
			padding: 20px 0;
		}

		.ka-approach__lead {
			margin-bottom: 32px;
		}

		.ka-approach article {
			padding: 24px 0;
		}

		.ka-proof__heading {
			margin-bottom: 56px;
		}

		.ka-proof__item {
			gap: 26px;
			margin-bottom: 72px;
		}
	}
</style>
