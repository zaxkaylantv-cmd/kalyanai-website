---
import ButtonPrimary from '../components/ButtonPrimary.astro';
import Eyebrow from '../components/Eyebrow.astro';
import Layout from '../layouts/Layout.astro';
import SectionHeading from '../components/SectionHeading.astro';

const caseStudies = [
	{
		sector: 'Finance operations',
		title: 'Spa by Kaajal',
		system: 'Finance admin and visibility system',
		summary: 'A system built around salon finance work, bringing invoices, receipts, tips, missing items and accountant-ready exports into one clearer place.',
		proof: 'Finance admin reduced from around 4 to 6 hours a week to around 30 minutes.',
		href: '/case-studies/spa-by-kaajal/',
		image: '/images/case-studies/after-dashboard.png',
		alt: 'Spa by Kaajal finance dashboard showing invoices, receipts, cashflow, tips and overdue items in one place.',
		label: 'Finance dashboard with demo data',
		width: 872,
		height: 572,
	},
	{
		sector: 'Live booking and operations',
		title: 'Jas\'s School of Spice',
		system: 'Customer booking and operations system',
		summary: 'A live system for cookery classes covering bookings, payments, vouchers, reminders, customer messages, owner alerts and protected operational controls.',
		proof: 'Live booking and operations flow for customers and the owner behind the scenes.',
		href: '/case-studies/jas-school-of-spice/',
		image: '/images/case-studies/jas-school-of-spice/jas-school-of-spice-customer-homepage.png',
		alt: 'Jas\'s School of Spice customer homepage showing class booking options.',
		label: 'Live customer booking homepage',
		width: 891,
		height: 946,
	},
	{
		sector: 'Internal operating proof',
		title: 'Kalyan AI Internal Operating Stack',
		system: 'Controlled commercial operating system',
		summary: 'Kalyan AI’s own system for lead generation, outreach, replies, CRM, business visibility, reference context, system health and owner control.',
		proof: 'Internal proof that the same operating principles are used inside Kalyan AI.',
		href: '/case-studies/kalyan-ai-internal-stack/',
		image: '/images/case-studies/kalyan-ai-internal-stack/kalyan-ai-internal-operating-dashboard.png',
		alt: 'Kalyan AI internal operating dashboard showing business activity and system health.',
		label: 'Internal operating dashboard',
		badge: 'Protected view',
		width: 1487,
		height: 964,
	},
];

const commonThreads = [
	{
		title: 'Built around how the business works',
		copy: 'The system starts with the real operating pattern, not a template looking for somewhere to fit.',
	},
	{
		title: 'Owner stays in control',
		copy: 'Each system keeps the owner closer to the work, the exceptions, the approvals and the visibility that matter.',
	},
	{
		title: 'Proof before promises',
		copy: 'The work is judged against real systems, real screens and specific operating problems, not broad claims.',
	},
	{
		title: 'Supported after delivery',
		copy: 'Where support is part of the engagement, Kalyan AI stays involved after launch so the system can settle into real use.',
	},
];
---

<Layout
	title="Kalyan AI Case Studies"
	description="See real proof of AI systems built around how businesses actually work, including Spa by Kaajal, Jas's School of Spice and Kalyan AI's internal operating stack."
	showFinalCta={false}
>
	<section class="cases-hero">
		<div class="ka-wrap">
			<div class="cases-hero__inner">
				<Eyebrow tone="dark">Case studies</Eyebrow>
				<h1>Business systems built around real operations</h1>
				<p>Real systems built, hosted and supported by Kalyan AI around how businesses actually work, with owner control, practical visibility and clear proof from delivery.</p>
			</div>
		</div>
	</section>

	<section class="ka-section ka-section-white cases-overview">
		<div class="ka-wrap">
			<div class="cases-overview__grid">
				<SectionHeading
					eyebrow="Proof overview"
					title="The proof comes from real client systems and Kalyan AI’s own operating stack."
					highlight="real client systems"
					tone="dark"
				/>
				<div class="cases-copy-stack">
					<p>These case studies show systems built around real business operations: finance admin, customer booking, owner alerts, protected controls, commercial visibility and ongoing operational support.</p>
					<p>The point is not to show generic AI concepts. The point is to show how a business problem becomes a system that works inside the way the business already runs.</p>
					<p>The internal operating stack is included because Kalyan AI applies the same principle to its own commercial activity: controlled systems, clear visibility and human judgement kept in the loop.</p>
				</div>
			</div>
		</div>
	</section>

	<section class="ka-section ka-section-paper cases-selection">
		<div class="ka-wrap">
			<SectionHeading
				eyebrow="Selected systems"
				title="Three examples of systems built for real operational use."
				highlight="real operational use."
				lead="Each example is tied to a specific business setting, a specific operating need and a factual proof point."
			/>
			<div class="cases-grid">
				{caseStudies.map((study, index) => (
					<article class="case-card">
						<figure class="case-shot">
							<div class="case-shot__chrome" aria-hidden="true">
								<span></span>
								<span></span>
								<span></span>
								<div></div>
								{study.badge && <strong>{study.badge}</strong>}
							</div>
							<div class="case-shot__screen">
								<img
									src={study.image}
									alt={study.alt}
									width={study.width}
									height={study.height}
									loading="eager"
									fetchpriority={index === 0 ? 'high' : 'auto'}
								/>
							</div>
							<figcaption>{study.label}</figcaption>
						</figure>
						<div class="case-card__body">
							<p class="case-card__sector">{study.sector}</p>
							<h2>{study.title}</h2>
							<p class="case-card__summary">{study.summary}</p>
							<div class:list={['case-card__proof', index === 0 && 'case-card__proof--gold']}>
								<span>Proof point</span>
								<strong>{study.proof}</strong>
							</div>
							<a href={study.href}>Read the case study</a>
						</div>
					</article>
				))}
			</div>
		</div>
	</section>

	<section class="ka-section ka-section-deep cases-thread">
		<div class="ka-wrap">
			<div class="cases-thread__grid">
				<SectionHeading
					eyebrow="Common thread"
					title="The pattern is controlled delivery around the way the business already runs."
					lead="Different businesses need different systems. The shared principle is that each system should earn its place inside the operation and keep the owner closer to what matters."
					tone="dark"
				/>
				<div class="cases-thread__items">
					{commonThreads.map((item, index) => (
						<article>
							<span>{String(index + 1).padStart(2, '0')}</span>
							<h3>{item.title}</h3>
							<p>{item.copy}</p>
						</article>
					))}
				</div>
			</div>
		</div>
	</section>

	<section class="ka-section ka-section-paper cases-cta">
		<div class="ka-wrap">
			<div class="cases-cta__inner">
				<Eyebrow>Start here</Eyebrow>
				<h2>Find the right first system for your business.</h2>
				<p>The Business AI Blueprint is a focused paid review that helps identify where AI can create real value, what system is worth building first, and whether there is a clear business case before a larger build.</p>
				<ButtonPrimary href="/blueprint" label="Start with the Blueprint" data-plausible="BookACall" />
			</div>
		</div>
	</section>
</Layout>

<style>
	.cases-hero {
		background:
			linear-gradient(100deg, rgba(8, 20, 40, 0.98) 20%, rgba(8, 20, 40, 0.78) 62%, rgba(8, 20, 40, 0.98) 100%),
			radial-gradient(circle at 78% 24%, rgba(0, 183, 198, 0.23), transparent 36%),
			var(--navy-deep);
		border-bottom: 1px solid var(--line-dark);
		color: var(--white);
	}

	.cases-hero__inner {
		max-width: 900px;
		padding: 116px 0 132px;
		text-align: left;
	}

	.cases-hero h1 {
		max-width: 15ch;
		margin: 0 0 24px;
		color: var(--white);
		font-size: clamp(48px, 6vw, 78px);
		font-weight: 500;
	}

	.cases-hero p {
		max-width: 54ch;
		color: var(--body-light);
		font-size: 18px;
		line-height: 1.66;
	}

	.cases-overview {
		background: var(--navy);
		border-bottom: 1px solid var(--line-dark);
		color: var(--white);
	}

	.cases-overview .cases-copy-stack {
		color: var(--body-light);
	}

	.cases-overview__grid,
	.cases-thread__grid {
		display: grid;
		grid-template-columns: 0.9fr 1.1fr;
		gap: 64px;
		align-items: start;
	}

	.cases-copy-stack {
		display: grid;
		gap: 18px;
		max-width: 60ch;
		color: var(--body);
		font-size: 17px;
		line-height: 1.68;
		text-align: left;
	}

	.cases-grid {
		display: grid;
		grid-template-columns: repeat(3, minmax(0, 1fr));
		gap: 20px;
		margin-top: 54px;
		align-items: stretch;
	}

	.case-card {
		display: grid;
		grid-template-rows: auto 1fr;
		gap: 22px;
		min-height: 100%;
		padding: 22px;
		border: 1px solid var(--line-light);
		border-radius: 16px;
		background: var(--white);
		box-shadow: 0 30px 62px -48px rgba(11, 18, 32, 0.34);
		text-align: left;
	}

	.case-card__body {
		display: grid;
		grid-template-rows: auto auto 1fr auto auto;
		gap: 14px;
	}

	.case-card__sector,
	.case-card__proof span {
		margin: 0;
		color: var(--teal-deep);
		font-family: "JetBrains Mono", ui-monospace, SFMono-Regular, Menlo, monospace;
		font-size: 11px;
		font-weight: 500;
		letter-spacing: 0.11em;
		text-transform: uppercase;
	}

	.case-card h2 {
		margin: 0;
		color: var(--ink);
		font-size: clamp(25px, 2.3vw, 33px);
		font-weight: 500;
	}

	.case-card__summary {
		color: var(--body);
		font-size: 15px;
		line-height: 1.62;
	}

	.case-card__proof {
		display: grid;
		gap: 8px;
		padding: 15px;
		border: 1px solid rgba(0, 183, 198, 0.22);
		border-radius: 12px;
		background: linear-gradient(135deg, rgba(0, 183, 198, 0.08), rgba(255, 255, 255, 0.86));
	}

	.case-card__proof strong {
		color: var(--ink);
		font-family: "Fraunces", Georgia, serif;
		font-size: 20px;
		font-weight: 600;
		line-height: 1.12;
	}

	.case-card__proof--gold strong {
		color: var(--gold);
	}

	.case-card a {
		justify-self: start;
		display: inline-flex;
		align-items: center;
		min-height: 44px;
		padding: 12px 18px;
		border-radius: 10px;
		background: var(--teal);
		color: #04222a;
		font-size: 14px;
		font-weight: 800;
		line-height: 1;
		text-decoration: none;
		box-shadow: 0 14px 34px -16px rgba(0, 183, 198, 0.58);
		transition:
			transform 150ms ease,
			box-shadow 150ms ease;
	}

	.case-card a:hover {
		transform: translateY(-2px);
		box-shadow: 0 20px 44px -16px rgba(0, 183, 198, 0.70);
	}

	.case-shot {
		margin: 0;
	}

	.case-shot__chrome {
		display: flex;
		align-items: center;
		gap: 6px;
		padding: 10px 12px;
		border: 1px solid var(--line-light);
		border-bottom: 0;
		border-radius: 13px 13px 0 0;
		background: var(--white);
	}

	.case-shot__chrome span {
		width: 9px;
		height: 9px;
		border-radius: 999px;
		background: #d8e0ea;
	}

	.case-shot__chrome div {
		height: 8px;
		flex: 1;
		max-width: 180px;
		margin-left: 10px;
		border-radius: 999px;
		background: #eef3f7;
	}

	.case-shot__chrome strong {
		padding: 5px 8px;
		border-radius: 5px;
		background: rgba(7, 17, 31, 0.72);
		color: var(--teal-soft);
		font-family: "JetBrains Mono", ui-monospace, SFMono-Regular, Menlo, monospace;
		font-size: 10px;
		font-weight: 500;
		letter-spacing: 0.08em;
		line-height: 1;
		text-transform: uppercase;
	}

	.case-shot__screen {
		overflow: hidden;
		aspect-ratio: 16 / 10;
		border: 1px solid var(--line-light);
		border-radius: 0 0 13px 13px;
		background: #f6f9fc;
		box-shadow: 0 30px 58px -34px rgba(11, 18, 32, 0.38);
	}

	.case-shot__screen img {
		display: block;
		width: 100%;
		max-width: 100%;
		height: 100%;
		object-fit: contain;
		object-position: top center;
		position: static;
		opacity: 1;
		filter: none;
	}

	.case-shot figcaption {
		margin-top: 9px;
		color: #7c8b9c;
		font-family: "JetBrains Mono", ui-monospace, SFMono-Regular, Menlo, monospace;
		font-size: 11px;
		line-height: 1.5;
		text-align: left;
	}

	.cases-thread {
		position: relative;
		overflow: hidden;
		border-top: 1px solid var(--line-dark);
		border-bottom: 1px solid var(--line-dark);
	}

	.cases-thread::before {
		content: "";
		position: absolute;
		inset: auto -8% -34% 48%;
		width: 760px;
		height: 560px;
		background: radial-gradient(circle, rgba(0, 183, 198, 0.14), transparent 68%);
		pointer-events: none;
	}

	.cases-thread__items {
		position: relative;
		z-index: 2;
		display: grid;
		grid-template-columns: 1fr 1fr;
		gap: 16px;
	}

	.cases-thread__items article {
		padding: 24px;
		border: 1px solid var(--line-dark);
		border-radius: 16px;
		background: rgba(255, 255, 255, 0.045);
		text-align: left;
	}

	.cases-thread__items span {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		width: 34px;
		height: 34px;
		margin-bottom: 22px;
		border: 1px solid rgba(63, 216, 227, 0.34);
		border-radius: 9px;
		background: rgba(0, 183, 198, 0.13);
		color: var(--teal-soft);
		font-family: "JetBrains Mono", ui-monospace, SFMono-Regular, Menlo, monospace;
		font-size: 11px;
	}

	.cases-thread__items h3 {
		margin: 0 0 10px;
		color: var(--white);
		font-size: 23px;
		font-weight: 600;
	}

	.cases-thread__items p {
		color: var(--body-light);
		font-size: 15px;
		line-height: 1.62;
	}

	.cases-cta {
		position: relative;
		overflow: hidden;
		background: var(--navy-deep);
		border-top: 1px solid var(--line-dark);
	}

	.cases-cta::before {
		content: "";
		position: absolute;
		bottom: -220px;
		left: 50%;
		width: 780px;
		height: 540px;
		transform: translateX(-50%);
		background: radial-gradient(circle, rgba(0, 183, 198, 0.10), transparent 64%);
		pointer-events: none;
	}

	.cases-cta__inner {
		position: relative;
		z-index: 2;
		max-width: 46ch;
		padding: 34px;
		border: 1px solid var(--line-dark);
		border-radius: 16px;
		background: rgba(255, 255, 255, 0.04);
		box-shadow: none;
		text-align: left;
	}

	.cases-cta h2 {
		margin: 0 0 18px;
		color: var(--white);
		font-size: clamp(30px, 3.7vw, 42px);
		font-weight: 500;
	}

	.cases-cta p {
		margin-bottom: 30px;
		color: var(--body-light);
		font-size: 17px;
		line-height: 1.62;
	}

	.cases-cta :global(.ka-eyebrow--light) {
		color: var(--teal-soft);
	}

	.cases-cta :global(.ka-eyebrow--light)::before {
		background: var(--gold-soft);
	}

	@media (max-width: 980px) {
		.cases-overview__grid,
		.cases-thread__grid,
		.cases-grid,
		.cases-thread__items {
			grid-template-columns: 1fr;
		}
	}

	@media (max-width: 640px) {
		.cases-hero__inner {
			padding: 78px 0 92px;
		}

		.case-card,
		.cases-thread__items article,
		.cases-cta__inner {
			padding: 22px;
		}
	}
</style>
