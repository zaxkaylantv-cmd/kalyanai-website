---
import Layout from '../layouts/Layout.astro';

const caseStudies = [
	{
		label: 'Finance admin and visibility system',
		title: 'Spa by Kaajal finance system',
		business: 'Beauty salon · London, UK',
		copy: 'A finance system built around how salon finance work actually moved, bringing invoices, receipts, tips, missing items and accountant-ready exports into one clearer place.',
		image: '/images/case-studies/after-dashboard.png',
		alt: 'Spa by Kaajal finance dashboard showing invoices, receipts, cashflow, tips and overdue items in one place.',
		href: '/case-studies/spa-by-kaajal',
	},
	{
		label: 'Live client booking and operations system',
		title: 'Jas’s School of Spice Booking System',
		business: 'Cookery school',
		copy: 'A live booking and operations system helping customers book, pay, buy vouchers and ask questions online, with clearer owner control behind the scenes.',
		image: '/images/case-studies/jas-school-of-spice/jas-school-of-spice-customer-homepage.png',
		alt: 'Jas’s School of Spice customer homepage showing class booking options.',
		href: '/case-studies/jas-school-of-spice',
	},
	{
		label: 'Internal proof system',
		title: 'Kalyan AI Internal Operating Stack',
		business: 'Kalyan AI',
		copy: 'How Kalyan AI runs its own commercial activity through a controlled internal system covering lead generation, outreach, replies, CRM handoff, follow-up and business visibility.',
		image: '/images/case-studies/kalyan-ai-internal-stack/kalyan-ai-internal-operating-dashboard.png',
		alt: 'Kalyan AI internal operating dashboard showing business activity and system health.',
		href: '/case-studies/kalyan-ai-internal-stack',
	},
];
---

<Layout title="Kalyan AI Case Studies" description="See real proof of AI systems built around how businesses actually work, including Spa by Kaajal and the live booking system for Jas's School of Spice.">
	<section class="mx-auto flex max-w-5xl flex-col gap-6 px-4 pb-10 md:gap-8 md:px-6 md:pb-16">
		<div class="ka-card space-y-5 rounded-3xl bg-white/80 p-4 text-center shadow-[0_10px_50px_-40px_rgba(0,0,0,0.5)] backdrop-blur max-md:-mx-2 md:p-8">
			<p class="inline-flex items-center rounded-full border-2 border-[var(--primary)] bg-white px-3 py-1 text-xs font-medium text-[var(--brand-navy)]">
				Case studies
			</p>
			<h1 class="mx-auto max-w-3xl text-3xl font-semibold text-[var(--brand-navy)] md:text-5xl">Business systems <span class="text-[var(--primary)]">built around real operations.</span></h1>
			<p class="copy-narrow mx-auto text-[var(--muted)] max-md:text-left max-md:text-[15px] md:text-lg">
				Examples of Kalyan AI systems built around how a business actually works, with owner control, visibility and support after delivery.
			</p>
		</div>

		<div class="grid items-stretch gap-6 lg:grid-cols-3">
			{caseStudies.map((study) => (
				<article class="ka-card flex h-full min-h-full flex-col overflow-hidden rounded-3xl bg-white/80 shadow-[0_10px_50px_-40px_rgba(0,0,0,0.5)] backdrop-blur max-md:-mx-2">
					<a href={study.href} class="block shrink-0">
						<div class="aspect-[16/11] overflow-hidden border-b border-[var(--border-subtle)] bg-white">
							<img
								src={study.image}
								alt={study.alt}
								class="h-full w-full object-cover"
								loading="lazy"
							/>
						</div>
					</a>
					<div class="flex min-h-0 flex-1 flex-col p-4 md:p-6">
						<div class="flex-1 space-y-4 md:min-h-[13.5rem] lg:min-h-[18rem]">
							<p class="text-sm font-semibold text-[var(--primary)]">{study.label}</p>
							<div class="space-y-2">
								<h2 class="text-2xl font-semibold text-[var(--brand-navy)]">{study.title}</h2>
								<p class="text-sm font-medium text-[var(--muted)]">{study.business}</p>
							</div>
							<p class="text-[var(--muted)] max-md:text-[15px]">{study.copy}</p>
						</div>
						<div class="mt-auto pt-6">
							<a href={study.href} class="inline-flex h-11 w-full items-center justify-center rounded-full bg-[var(--primary)] px-5 text-sm font-medium text-white shadow-sm transition hover:-translate-y-0.5 hover:bg-[var(--secondary)] sm:w-48">
								Read the case study
							</a>
						</div>
					</div>
				</article>
			))}
		</div>
	</section>
</Layout>
